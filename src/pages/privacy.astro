---
import BaseLayout from '../layouts/BaseLayout.astro';
const year = new Date().getFullYear();
---

<BaseLayout
  title="Privacy Policy | Proactive Pixels"
  description="Privacy Policy for Proactive Pixels LLC"
>
  <header class="site-header">
    <div class="site-header__inner">
      <a href="/" class="site-logo">Proactive Pixels</a>
    </div>
  </header>

  <main class="privacy">
    <div class="privacy__inner">
      <h1 class="privacy__title">Privacy Policy</h1>
      <p class="privacy__date">Last updated: {year}</p>

      <div class="privacy__body">
        <h2>Information We Collect</h2>
        <p>When you submit our form, we collect your first name, business type, and phone number. This information is used solely to conduct your free business assessment and deliver your report.</p>

        <h2>How We Use Your Information</h2>
        <p>Your information is used to contact you for your requested business assessment and to deliver your written report. We do not sell, rent, or share your personal information with third parties for marketing purposes.</p>

        <h2>AI Voice Assessment</h2>
        <p>Our assessment is conducted by Alex, an AI voice agent powered by Retell AI. By calling the number provided, you consent to your conversation being recorded and processed to generate your business report. Recordings are used solely for report generation and quality assurance.</p>

        <h2>Data Retention</h2>
        <p>We retain your information for as long as necessary to provide our services. You may request deletion of your data at any time by contacting us.</p>

        <h2>Contact</h2>
        <p>For privacy questions or data deletion requests, contact us at: <a href="mailto:hello@proactivepixels.com">hello@proactivepixels.com</a></p>

        <p class="privacy__footer">&copy; {year} Proactive Pixels LLC. All rights reserved.</p>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .site-header {
    padding: 20px 24px;
    border-bottom: 1px solid var(--color-border);
  }

  .site-header__inner {
    max-width: 800px;
    margin: 0 auto;
  }

  .site-logo {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    color: var(--color-navy);
    text-decoration: none;
  }

  .privacy {
    padding: 60px 24px 100px;
  }

  .privacy__inner {
    max-width: 680px;
    margin: 0 auto;
  }

  .privacy__title {
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 8px;
    letter-spacing: -0.02em;
  }

  .privacy__date {
    font-size: 14px;
    color: var(--color-muted);
    margin-bottom: 48px;
  }

  .privacy__body h2 {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 600;
    color: var(--color-text);
    margin: 32px 0 12px;
  }

  .privacy__body p {
    font-size: 16px;
    line-height: 1.75;
    color: var(--color-text-light);
    margin-bottom: 16px;
  }

  .privacy__body a {
    color: var(--color-navy);
    text-decoration: underline;
  }

  .privacy__footer {
    margin-top: 60px;
    font-size: 13px;
    color: var(--color-muted);
  }
</style>
