---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import SiteFooter from '../components/SiteFooter.astro';
const year = new Date().getFullYear();
---

<BaseLayout
  title="Privacy Policy | ProActive Pixels"
  description="Privacy Policy for ProActive Pixels LLC — how we collect, use, and protect your information."
>
  <Nav />

  <main class="privacy-page">
    <div class="container--narrow">
      <div class="privacy-header">
        <h1 class="privacy-title">Privacy Policy</h1>
        <p class="privacy-date">Last updated: {year}</p>
      </div>

      <div class="privacy-body">
        <h2>Information We Collect</h2>
        <p>When you submit our assessment form, we collect your first name, business type, and phone number. This information is used solely to conduct your free business assessment and deliver your personalized Leak Report.</p>

        <h2>How We Use Your Information</h2>
        <p>Your information is used to contact you for your requested business assessment and to deliver your written report. We do not sell, rent, or share your personal information with third parties for marketing purposes.</p>

        <h2>AI Voice Assessment</h2>
        <p>Our assessment is conducted by Alex, an AI voice agent powered by Retell AI. By calling the number provided, you consent to your conversation being recorded and processed to generate your business report. Recordings are used solely for report generation and quality assurance.</p>

        <h2>Data Retention</h2>
        <p>We retain your information for as long as necessary to provide our services. You may request deletion of your data at any time by contacting us.</p>

        <h2>Contact</h2>
        <p>For privacy questions or data deletion requests, contact us at: <a href="mailto:solutions@proactivepixels.com">solutions@proactivepixels.com</a></p>

        <p class="privacy-footer">&copy; {year} ProActive Pixels LLC. All rights reserved.</p>
      </div>
    </div>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .privacy-page {
    padding: 72px 0 96px;
    background: var(--color-bg);
  }

  .privacy-header {
    margin-bottom: 48px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--color-border);
  }

  .privacy-title {
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.02em;
    margin-bottom: 8px;
  }

  .privacy-date {
    font-size: 14px;
    color: var(--color-muted);
  }

  .privacy-body h2 {
    font-size: 18px;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.01em;
    margin: 40px 0 12px;
  }

  .privacy-body h2:first-child {
    margin-top: 0;
  }

  .privacy-body p {
    font-size: 16px;
    line-height: 1.75;
    color: var(--color-body);
    margin-bottom: 16px;
    max-width: 65ch;
    text-wrap: pretty;
  }

  .privacy-body a {
    color: var(--pp-sky);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .privacy-body a:hover {
    color: var(--pp-ocean);
  }

  .privacy-footer {
    margin-top: 56px;
    padding-top: 24px;
    border-top: 1px solid var(--color-border);
    font-size: 13px;
    color: var(--color-muted);
  }
</style>
