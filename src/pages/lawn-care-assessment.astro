---
import NicheAssessmentLayout from '../layouts/NicheAssessmentLayout.astro';
---

<NicheAssessmentLayout
  metaTitle="Free Lawn Care Business Leak Report | ProActive Pixels"
  metaDescription="Lawn care companies lose $10,000–$35,000 a year to missed spring booking calls and recurring clients who drift away. Get your free Leak Report in 12 minutes."
  nicheLabel="For Lawn Care Companies"
  lossRange="$10,000 to $35,000"
  nicheValue="Lawn care"
  objections={[
    {
      quote: '"Spring is already here — I don\'t have time to set anything up."',
      answer: "Spring is the only time this matters enough to act on. Most lawn care clients are live within 72 hours. We do the setup. You stay in the field. The system handles the calls you can't get to.",
    },
    {
      quote: '"My clients like dealing with me directly."',
      answer: "They like getting a response. When you're running a mower at 2pm and someone calls to book, they don't want to leave a voicemail. An AI that books the call immediately feels more personal than a voicemail that gets returned two days later.",
    },
    {
      quote: '"This seems expensive for a lawn care operation."',
      answer: "The report will give you a number. If the number is real, the math works. If it's not real for your operation, you'll know in 12 minutes and we won't waste each other's time.",
    },
    {
      quote: '"This is probably just a sales pitch."',
      answer: "The report is yours whether you work with us or not. No follow-up unless you want one. We're fine either way.",
    },
  ]}
/>
