---
import NicheAssessmentLayout from '../layouts/NicheAssessmentLayout.astro';
---

<NicheAssessmentLayout
  metaTitle="Free HVAC Business Leak Report | ProActive Pixels"
  metaDescription="HVAC companies lose $30,000–$90,000 a year to missed after-hours emergency calls and slow quote follow-up. Get your free Leak Report in 12 minutes."
  nicheLabel="For HVAC Companies"
  lossRange="$30,000 to $90,000"
  nicheValue="HVAC"
  nicheOperator="HVAC operators"
  objections={[
    {
      quote: '"We already have an answering service."',
      answer: "An answering service takes a message. A Voice AI qualifies the lead, books the appointment into your calendar, and sends a confirmation text — all before your tech finishes the current job. The difference shows up in your booking rate.",
    },
    {
      quote: '"Our busy season is summer — not right now."',
      answer: "Right now is when you build the system. When your phone rings 80 times a day in July, you don't have time to set anything up. The operators who win summer build their infrastructure in the off-season.",
    },
    {
      quote: '"I\'m not sure AI works for emergency dispatch."',
      answer: "Emergency calls are exactly what this is built for. The AI identifies urgent calls, collects the address and issue, and immediately alerts your on-call tech — faster than a human dispatcher who's handling three calls at once.",
    },
    {
      quote: '"This is probably just a sales pitch."',
      answer: "The report is yours whether you work with us or not. No follow-up call unless you want one. Read it, hand it to your office manager, or ignore it. We're fine either way.",
    },
  ]}
/>
