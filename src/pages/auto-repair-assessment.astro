---
import NicheAssessmentLayout from '../layouts/NicheAssessmentLayout.astro';
---

<NicheAssessmentLayout
  metaTitle="Free Auto Repair Business Leak Report | ProActive Pixels"
  metaDescription="Auto repair shops lose $15,000–$50,000 a year to missed appointment calls, no vehicle status updates, and customers who never came back for their next service. Get your free Leak Report in 12 minutes."
  nicheLabel="For Auto Repair Shops"
  lossRange="$15,000 to $50,000"
  nicheValue="Auto repair"
  nicheOperator="auto repair shops"
  objections={[
    {
      quote: '"We stay busy year-round — I don\'t think we have this problem."',
      answer: "Busy isn't the same as full. The report isn't about whether your bays are occupied — it's about the customers who called while you were in a bay and never called back, and the ones who got their oil changed and you haven't heard from since. That's recurring revenue sitting idle.",
    },
    {
      quote: '"My customers come back already."',
      answer: "Some do. The ones who don't — the ones who went 14 months without coming in because nobody sent a service reminder — are the number in your report. Most shops are surprised how many there are.",
    },
    {
      quote: '"I have a service advisor who handles customer communication."',
      answer: "Your service advisor is outstanding when they're at the counter. The report shows what happens when they're on the phone, writing up a ticket, or it's after 6pm. Those are the gaps. That's where the revenue goes.",
    },
    {
      quote: '"This is probably just a sales pitch."',
      answer: "The report is yours whether you work with us or not. No follow-up unless you want one. We're fine either way.",
    },
  ]}
/>
