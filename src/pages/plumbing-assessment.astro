---
import NicheAssessmentLayout from '../layouts/NicheAssessmentLayout.astro';
---

<NicheAssessmentLayout
  metaTitle="Free Plumbing Business Leak Report | ProActive Pixels"
  metaDescription="Plumbing companies lose $20,000–$60,000 a year to missed emergency calls and slow booking. Get your free Leak Report in 12 minutes."
  nicheLabel="For Plumbing Companies"
  lossRange="$20,000 to $60,000"
  nicheValue="Plumbing"
  objections={[
    {
      quote: '"We handle after-hours calls ourselves."',
      answer: "You handle the ones you catch. The 2am burst pipe that goes to voicemail — that customer calls the next plumber on Google before you call back at 7am. That's the job this fixes.",
    },
    {
      quote: '"Most of our work is referrals — we don\'t need more leads."',
      answer: "Referrals call too. And they don't leave voicemails any more than cold leads do. The report shows you how many referrals are bouncing because nobody answered in time.",
    },
    {
      quote: '"Emergency work is unpredictable — I can\'t automate that."',
      answer: "You automate the intake, not the work. The AI answers, gets the address and issue, and pings your on-call tech immediately. You control when and whether to take the job. The AI just makes sure you hear about it.",
    },
    {
      quote: '"This is probably just a sales pitch."',
      answer: "The report is yours whether you work with us or not. No follow-up unless you want one. We're fine either way.",
    },
  ]}
/>
