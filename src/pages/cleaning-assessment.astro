---
import NicheAssessmentLayout from '../layouts/NicheAssessmentLayout.astro';
---

<NicheAssessmentLayout
  metaTitle="Free Cleaning Business Leak Report | ProActive Pixels"
  metaDescription="Cleaning businesses lose $15,000–$40,000 a year to missed booking calls and recurring clients who quietly stop scheduling. Get your free Leak Report in 12 minutes."
  nicheLabel="For Cleaning & Maid Services"
  lossRange="$15,000 to $40,000"
  nicheValue="Cleaning"
  objections={[
    {
      quote: '"We\'re already at capacity — we don\'t need more clients."',
      answer: "At capacity today doesn't mean at capacity in three months. Cleaning businesses have the highest client churn of any home service. The report shows you what your churn rate is costing you in replacement revenue every month.",
    },
    {
      quote: '"I handle bookings myself — it\'s not that complicated."',
      answer: "It's not complicated. It's the timing. A call you miss at 7pm because you're finishing a job is a client who books someone else by 7:30pm. The report shows you how often that's happening.",
    },
    {
      quote: '"I\'m worried automation will feel impersonal to my clients."',
      answer: "The clients who leave reviews rave about the clean — not how the booking was confirmed. A fast, professional booking experience builds trust. A missed call destroys it. Your clients don't notice the automation. They notice the response time.",
    },
    {
      quote: '"This is probably just a sales pitch."',
      answer: "The report is yours whether you work with us or not. No follow-up unless you want one. We're fine either way.",
    },
  ]}
/>
