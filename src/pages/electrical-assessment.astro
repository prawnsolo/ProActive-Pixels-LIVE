---
import NicheAssessmentLayout from '../layouts/NicheAssessmentLayout.astro';
---

<NicheAssessmentLayout
  metaTitle="Free Electrical Business Leak Report | ProActive Pixels"
  metaDescription="Electrical contractors lose $15,000–$50,000 a year to missed high-value calls and slow commercial estimates. Get your free Leak Report in 12 minutes."
  nicheLabel="For Electrical Contractors"
  lossRange="$15,000 to $50,000"
  nicheValue="Electrical"
  objections={[
    {
      quote: '"We\'re busy enough — we don\'t need more calls."',
      answer: "At capacity today doesn't mean at capacity in three months. Electrical businesses have seasonal dips, and the ones that fill their pipeline during slow periods are the ones that stay busy year-round. The report shows you what your fill rate actually is.",
    },
    {
      quote: '"Commercial clients don\'t work that way."',
      answer: "Commercial property managers absolutely respond to speed. A facilities manager emails about panel work on 6 units. You call back in 3 days. They've already signed with whoever responded in 3 hours. That's a $15,000 job.",
    },
    {
      quote: '"I handle scheduling myself."',
      answer: "While you're on a job site at $150–$300 an hour, a call to book a $2,000 job goes to voicemail. The math on that tradeoff is in the report.",
    },
    {
      quote: '"This is probably just a sales pitch."',
      answer: "The report is yours whether you work with us or not. No follow-up unless you want one. We're fine either way.",
    },
  ]}
/>
