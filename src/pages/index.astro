---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import SiteFooter from '../components/SiteFooter.astro';
---

<BaseLayout
  title="ProActive Pixels | AI & Automation for Local Service Businesses"
  description="We find the automation and AI opportunities hiding in your operations, implement the right solution, and maintain it. Most clients are live and generating ROI within 72 hours."
>
  <Nav />

  <main>

    <!-- HERO -->
    <section class="hero">
      <div class="container hero-inner">
        <div class="hero-content">
          <div class="section-label fade-in">AI & Automation for Service Businesses</div>
          <h1 class="hero-headline fade-in fade-in-delay-1">
            Your Business Is<br>
            <span class="headline-accent">Leaking Revenue.</span><br>
            We Find the Holes.
          </h1>
          <p class="hero-sub fade-in fade-in-delay-2">
            We audit your operations for automation and AI opportunities, implement the right solution,
            and keep it running — so you stop losing money to manual work and missed leads.
            Most clients are live within 72 hours.
          </p>
          <div class="hero-ctas fade-in fade-in-delay-3">
            <a href="/assessment" class="btn btn--primary btn--lg">Get Your Free Leak Report →</a>
          </div>
          <p class="hero-proof fade-in fade-in-delay-3">
            Free audit &bull; No commitment &bull; Results in days, not months
          </p>
        </div>
      </div>
    </section>

    <!-- HOOK BAR -->
    <div class="hook-bar fade-in">
      <div class="container">
        <p class="hook-text">
          If a lead calls after hours and no one answers: that's a leak.
          If your follow-up sequence stops after 2 emails: that's a leak.
          If your team is doing data entry that a bot could handle: that's a leak.
          <strong>We find every one of them.</strong>
        </p>
      </div>
    </div>

    <!-- PROCESS: FIND → IMPLEMENT → MAINTAIN -->
    <section class="section-process">
      <div class="container">
        <div class="section-header fade-in">
          <div class="section-label">How It Works</div>
          <h2 class="section-headline">We Do the Heavy Lifting.<br>You Keep the Revenue.</h2>
          <p class="section-sub">Three phases. No guesswork. No six-month timelines.</p>
        </div>

        <div class="process-steps">
          <div class="process-step fade-in">
            <div class="step-number">01</div>
            <div class="step-icon">🔍</div>
            <h3 class="step-title">Find</h3>
            <p class="step-desc">
              We map your customer journey from first contact to final invoice. Every manual touchpoint,
              every handoff, every place a lead could fall through the cracks. We come back with a
              prioritized list of what's costing you money and what to fix first.
            </p>
            <div class="step-result">Deliverable: Your Leak Report</div>
          </div>

          <div class="process-arrow fade-in fade-in-delay-1">→</div>

          <div class="process-step fade-in fade-in-delay-1">
            <div class="step-number">02</div>
            <div class="step-icon">⚡</div>
            <h3 class="step-title">Implement</h3>
            <p class="step-desc">
              We don't build custom software from scratch. We connect proven AI tools and automation
              platforms — the same ones used by businesses 10x your size — and configure them
              precisely for your workflow. Most solutions are live in 72 hours or less.
            </p>
            <div class="step-result">Deliverable: Working Solution, Live</div>
          </div>

          <div class="process-arrow fade-in fade-in-delay-2">→</div>

          <div class="process-step fade-in fade-in-delay-2">
            <div class="step-number">03</div>
            <div class="step-icon">🛡️</div>
            <h3 class="step-title">Maintain</h3>
            <p class="step-desc">
              AI tools drift. Integrations break. APIs update. We monitor your solutions, fix issues
              before they become problems, and continuously improve performance. You get a partner,
              not a one-time project.
            </p>
            <div class="step-result">Deliverable: Ongoing Peace of Mind</div>
          </div>
        </div>
      </div>
    </section>

    <!-- EXAMPLE SECTION -->
    <section class="section-example">
      <div class="container">
        <div class="example-inner">
          <div class="example-text fade-in">
            <div class="section-label">Most Common First Solution</div>
            <h2 class="section-headline">Never Miss Another Lead — Even at 2am</h2>
            <p class="section-sub">
              The #1 leak we find in service businesses: missed calls after hours. A prospect calls,
              no one answers, they call your competitor. Done.
            </p>
            <p class="example-body">
              Our most common first implementation is a Voice AI receptionist — it answers every call,
              qualifies leads with your exact questions, books appointments directly into your calendar,
              and sends follow-up texts automatically. Your competition is still using voicemail.
            </p>
            <ul class="example-wins">
              <li>✓ Answers 100% of calls, 24/7/365</li>
              <li>✓ Qualifies and books leads while you sleep</li>
              <li>✓ Handles FAQs so your team focuses on revenue work</li>
              <li>✓ Live in 48–72 hours, no new phone system needed</li>
            </ul>
            <a href="/services" class="btn btn--primary" style="margin-top: 16px;">See All Solutions →</a>
          </div>
          <div class="example-visual fade-in fade-in-delay-1">
            <div class="example-card">
              <div class="example-card-label">Before</div>
              <div class="example-metric bad">
                <span class="metric-num">43%</span>
                <span class="metric-label">of after-hours calls<br>go unanswered</span>
              </div>
              <div class="example-card-label" style="margin-top:24px;">After</div>
              <div class="example-metric good">
                <span class="metric-num">100%</span>
                <span class="metric-label">of calls answered,<br>qualified, and logged</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- WHY NOT JUST HIRE -->
    <section class="section-why">
      <div class="container">
        <div class="why-inner">
          <div class="why-left fade-in">
            <div class="section-label">Why ProActive Pixels</div>
            <h2 class="section-headline">Not an Agency. Not a Dev Shop. Not a Consultant.</h2>
            <p class="why-lead">
              We're operators. We've run service businesses. We know what it costs to miss a lead,
              lose a customer, or have a system break on a Friday afternoon.
            </p>
          </div>
          <div class="why-right fade-in fade-in-delay-1">
            <div class="why-compare">
              <div class="why-compare-row">
                <div class="why-col why-col--no">
                  <span class="why-col-label">Custom Dev Shop</span>
                  <p>Charges $30–50K to build from scratch. Takes months. You own the liability when it breaks.</p>
                </div>
                <div class="why-col why-col--no">
                  <span class="why-col-label">Strategy Consultant</span>
                  <p>Gives you a 40-page roadmap and disappears. Nothing is ever actually live.</p>
                </div>
              </div>
              <div class="why-divider-row">
                <div class="why-divider-label">vs.</div>
              </div>
              <div class="why-col why-col--yes">
                <span class="why-col-label">ProActive Pixels</span>
                <p>We implement proven tools in 72 hours, maintain them long-term, and alert you before things break. Results before month one ends.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- RESULTS -->
    <section class="section-results">
      <div class="container">
        <div class="results-inner">
          <div class="results-label fade-in">
            <div class="section-label">Results</div>
            <h2 class="section-headline">What Fixing the Leaks Actually Looks Like</h2>
          </div>
          <div class="results-featured fade-in fade-in-delay-1">
            <div class="featured-number">$18K</div>
            <div class="featured-story">
              <p class="featured-headline">HVAC company, month one.</p>
              <p class="featured-detail">They were missing 43% of after-hours calls. Every missed call was a $450–$900 job walking to a competitor. We installed a Voice AI receptionist. It went live in 68 hours. Three booked jobs in week one. The owner stopped counting at $18K in recovered revenue.</p>
              <a href="/work" class="results-link">Read all case studies →</a>
            </div>
          </div>
          <div class="results-secondary fade-in fade-in-delay-2">
            <div class="result-row">
              <span class="result-row-num">14 hrs</span>
              <span class="result-row-desc">saved per week — med-spa automated intake, confirmations, and no-show follow-ups</span>
            </div>
            <div class="result-row">
              <span class="result-row-num">31%</span>
              <span class="result-row-desc">increase in close rate — roofing company added an 8-touch automated follow-up sequence</span>
            </div>
            <div class="result-row">
              <span class="result-row-num">72 hrs</span>
              <span class="result-row-desc">median time from kickoff to live solution — no new hardware, no IT department</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA SECTION -->
    <section class="section-cta">
      <div class="container">
        <div class="cta-inner fade-in">
          <div class="section-label" style="color:#fff; opacity:0.75;">Free. No Commitment. No Catch.</div>
          <h2 class="cta-headline">Ready to Stop the Leaks?</h2>
          <p class="cta-sub">
            Tell us about your business. We'll come back with a personalized Leak Report — the specific
            automation and AI opportunities that could add revenue or save time within the next 30 days.
          </p>
          <a href="/assessment" class="btn btn--white btn--lg">Get Your Free Leak Report →</a>
          <p class="cta-fine">Takes 5 minutes. We respond within 1 business day.</p>
        </div>
      </div>
    </section>

  </main>

  <SiteFooter />
</BaseLayout>

<style>
  /* HERO */
  .hero {
    padding: 96px 0 80px;
    background: var(--color-bg);
  }

  .hero-inner {
    display: flex;
    align-items: center;
  }

  .hero-content {
    max-width: 680px;
  }

  .hero-headline {
    font-size: clamp(38px, 6vw, 66px);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin-bottom: 24px;
    text-wrap: balance;
  }

  .headline-accent {
    color: var(--pp-amber);
  }

  .hero-sub {
    font-size: 18px;
    color: var(--color-body);
    line-height: 1.65;
    max-width: 580px;
    margin-bottom: 36px;
    text-wrap: pretty;
  }

  .hero-ctas {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 20px;
  }

  .hero-proof {
    font-size: 13px;
    color: var(--pp-amber);
    font-weight: 600;
  }

  /* HOOK BAR */
  .hook-bar {
    background: var(--color-bg-dark);
    padding: 28px 0;
  }

  .hook-text {
    font-size: 16px;
    color: rgba(255,255,255,0.8);
    line-height: 1.6;
    max-width: 800px;
  }

  .hook-text strong {
    color: #ffffff;
  }

  /* PROCESS */
  .section-process {
    padding: 96px 0;
    background: var(--color-bg);
  }

  .section-header {
    margin-bottom: 64px;
  }

  .process-steps {
    display: flex;
    gap: 0;
    align-items: flex-start;
  }

  .process-step {
    flex: 1;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 36px 32px;
    box-shadow: var(--shadow-card);
  }

  .process-arrow {
    flex-shrink: 0;
    width: 48px;
    text-align: center;
    font-size: 28px;
    color: var(--pp-amber);
    padding-top: 56px;
  }

  .step-number {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--pp-amber);
    margin-bottom: 12px;
  }

  .step-icon {
    font-size: 36px;
    margin-bottom: 16px;
    line-height: 1;
  }

  .step-title {
    font-size: 24px;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.02em;
    margin-bottom: 12px;
  }

  .step-desc {
    font-size: 15px;
    color: var(--color-body);
    line-height: 1.65;
    margin-bottom: 20px;
  }

  .step-result {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--pp-navy);
    background: rgba(245,166,35,0.18);
    padding: 6px 12px;
    border-radius: var(--radius-pill);
    display: inline-block;
  }

  /* EXAMPLE */
  .section-example {
    padding: 96px 0;
    background: var(--color-bg-section);
  }

  .example-inner {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 64px;
    align-items: center;
  }

  .example-body {
    font-size: 16px;
    color: var(--color-body);
    line-height: 1.7;
    margin-bottom: 24px;
  }

  .example-wins {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .example-wins li {
    font-size: 15px;
    color: var(--color-body);
    font-weight: 500;
  }

  .example-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 36px 32px;
    box-shadow: var(--shadow-card);
  }

  .example-card-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 12px;
  }

  .example-metric {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .metric-num {
    font-size: 48px;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .metric-label {
    font-size: 14px;
    color: var(--color-muted);
    line-height: 1.4;
  }

  .example-metric.bad .metric-num { color: #DC2626; }
  .example-metric.good .metric-num { color: var(--pp-amber); }

  /* WHY */
  .section-why {
    padding: 96px 0;
    background: var(--color-bg);
  }

  .why-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }

  .why-lead {
    font-size: 16px;
    color: var(--color-body);
    line-height: 1.7;
    text-wrap: pretty;
  }

  .why-compare {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .why-compare-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    padding-bottom: 24px;
  }

  .why-divider-row {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 12px 0;
    margin-bottom: 24px;
  }

  .why-divider-row::before,
  .why-divider-row::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--color-border);
  }

  .why-divider-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .why-col {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .why-col-label {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .why-col p {
    font-size: 13px;
    line-height: 1.6;
  }

  .why-col--no .why-col-label {
    color: var(--color-muted);
    text-decoration: line-through;
    text-decoration-color: rgba(93, 100, 148, 0.4);
  }

  .why-col--no p {
    color: var(--color-muted);
  }

  .why-col--yes {
    padding: 20px 24px;
    background: rgba(245,166,35,0.08);
    border: 1px solid rgba(245,166,35,0.28);
    border-radius: var(--radius-md);
  }

  .why-col--yes .why-col-label {
    color: var(--pp-amber);
  }

  .why-col--yes p {
    color: var(--color-body);
    font-size: 14px;
  }

  /* RESULTS */
  .section-results {
    padding: 96px 0;
    background: var(--color-bg-section);
  }

  .results-inner {
    display: grid;
    grid-template-columns: 240px 1fr;
    grid-template-rows: auto auto;
    gap: 48px 80px;
  }

  .results-label {
    grid-column: 1;
    grid-row: 1;
  }

  .results-featured {
    grid-column: 2;
    grid-row: 1 / 3;
    display: flex;
    gap: 32px;
    align-items: flex-start;
    padding: 36px 40px;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
  }

  .featured-number {
    font-size: 64px;
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--pp-amber);
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
  }

  .featured-headline {
    font-size: 15px;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 10px;
  }

  .featured-detail {
    font-size: 15px;
    color: var(--color-body);
    line-height: 1.7;
    margin-bottom: 14px;
    text-wrap: pretty;
  }

  .results-link {
    font-size: 14px;
    font-weight: 600;
    color: var(--pp-sky);
    text-decoration: none;
    transition: color 0.15s;
  }

  .results-link:hover { color: var(--pp-ocean); }

  .results-secondary {
    grid-column: 1;
    grid-row: 2;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .result-row {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 16px 0;
    border-top: 1px solid var(--color-border);
  }

  .result-row:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .result-row-num {
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--color-text);
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .result-row-desc {
    font-size: 13px;
    color: var(--color-muted);
    line-height: 1.5;
  }

  /* CTA */
  .section-cta {
    padding: 96px 0;
    background: var(--pp-navy);
  }

  [data-theme="dark"] .section-cta {
    background: var(--color-bg-dark);
  }

  .cta-inner {
    text-align: center;
    max-width: 640px;
    margin: 0 auto;
  }

  .cta-headline {
    font-size: clamp(32px, 5vw, 52px);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: #ffffff;
    margin-bottom: 20px;
  }

  .cta-sub {
    font-size: 17px;
    color: rgba(255,255,255,0.8);
    line-height: 1.65;
    margin-bottom: 36px;
  }

  .cta-fine {
    margin-top: 16px;
    font-size: 13px;
    color: rgba(255,255,255,0.68);
  }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .process-steps {
      flex-direction: column;
      gap: 24px;
    }
    .process-arrow {
      transform: rotate(90deg);
      padding-top: 0;
      width: 100%;
    }
    .example-inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .why-inner {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .results-inner {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
    }
    .results-featured {
      grid-column: 1;
      grid-row: 2;
    }
    .results-secondary {
      grid-column: 1;
      grid-row: 3;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding: 64px 0 56px;
    }
    .hero-ctas {
      flex-direction: column;
      gap: 12px;
    }
    .hero-ctas .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
