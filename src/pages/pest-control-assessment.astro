---
import NicheAssessmentLayout from '../layouts/NicheAssessmentLayout.astro';
---

<NicheAssessmentLayout
  metaTitle="Free Pest Control Business Leak Report | ProActive Pixels"
  metaDescription="Pest control companies lose $15,000–$45,000 a year to missed urgent infestation calls and recurring contracts that quietly lapse. Get your free Leak Report in 12 minutes."
  nicheLabel="For Pest Control Companies"
  lossRange="$15,000 to $45,000"
  nicheValue="Pest control"
  nicheOperator="pest control operators"
  objections={[
    {
      quote: '"We have a booking system already."',
      answer: "A booking system manages existing clients. This is about the leads that never make it into the system because nobody answered fast enough, or the contracts that fell out because no one sent a renewal. That revenue doesn't show up in your booking system — it just doesn't show up.",
    },
    {
      quote: '"Our busy season is spring and summer — not right now."',
      answer: "Right now is when you build the system. When spring hits and your phone rings 40 times a day, you don't have time to set anything up. The operators who win busy season build their infrastructure in the off-season.",
    },
    {
      quote: '"I\'m not sure this works for a service area business."',
      answer: "Service area businesses are exactly what this is built for. The report will show you how your specific call volume, average contract value, and response patterns translate into a dollar number. If the number doesn't justify the change, we'll tell you.",
    },
    {
      quote: '"This is probably just a sales pitch."',
      answer: "The report is yours whether you work with us or not. No follow-up unless you want one. We're fine either way.",
    },
  ]}
/>
