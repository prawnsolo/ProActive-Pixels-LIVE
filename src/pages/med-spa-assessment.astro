---
import NicheAssessmentLayout from '../layouts/NicheAssessmentLayout.astro';
---

<NicheAssessmentLayout
  metaTitle="Free Med Spa Business Leak Report | ProActive Pixels"
  metaDescription="Med spas lose $20,000–$65,000 a year to missed consultation requests, no-show gaps, and memberships that lapse without a renewal touchpoint. Get your free Leak Report in 12 minutes."
  nicheLabel="For Med Spas & Aesthetics"
  lossRange="$20,000 to $65,000"
  nicheValue="Med spa/Aesthetics"
  nicheOperator="med spas"
  objections={[
    {
      quote: '"We require a consultation before booking treatments."',
      answer: "The consultation is the first booking. A potential client requests one at 9pm, gets no response until the next morning, and books the med spa down the street that responded at 9:02pm. The AI books the consultation — not the treatment. That part is still yours.",
    },
    {
      quote: '"Our clients are mostly referrals — we don\'t need to chase leads."',
      answer: "Referrals expect the same fast response as everyone else. A referred client who texts after hours and hears nothing until the next business day is a referral who wonders if the recommendation was as good as they heard. Speed is the first impression.",
    },
    {
      quote: '"We have a front desk for this."',
      answer: "Your front desk is exceptional from 9 to 5. The report tells you what's happening at 7pm, on Saturdays, and during the 40 minutes when your front desk is with another client and the phone rings. That's where the revenue is going.",
    },
    {
      quote: '"This is probably just a sales pitch."',
      answer: "The report is yours whether you work with us or not. No follow-up unless you want one. We're fine either way.",
    },
  ]}
/>
