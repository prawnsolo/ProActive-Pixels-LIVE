---
const steps = [
  {
    number: '01',
    title: 'Fill Out the Form',
    description:
      'A business owner lands on proactivepixels.com and fills out a three-field form: First Name, Business Type, Phone Number.',
  },
  {
    number: '02',
    title: 'Data Is Saved',
    description:
      'Their data is saved to a Supabase database, indexed by phone number.',
  },
  {
    number: '03',
    title: 'They Call Alex',
    description:
      'After submitting, they see Alex\'s Retell phone number and call it.',
  },
  {
    number: '04',
    title: 'Retell Fires a Webhook',
    description:
      'Retell receives the inbound call and immediately fires a webhook to this system with the caller\'s phone number.',
  },
  {
    number: '05',
    title: 'Lookup in Under a Second',
    description:
      'This system looks up that phone number in Supabase, retrieves the caller\'s name and niche, maps the niche to the correct Retell agent ID, and returns that information to Retell in under a second.',
  },
  {
    number: '06',
    title: 'Right Agent, Right Greeting',
    description:
      'Retell connects the caller to the right niche-specific agent, who greets them by name and speaks fluently about their industry.',
  },
  {
    number: '07',
    title: 'Fallback If Not Found',
    description:
      'If the phone number isn\'t found — caller used a different phone, never filled out the form — a fallback intake agent answers, collects their info, and routes them manually.',
  },
];
---

<section class="hiw" id="how-it-works">
  <div class="hiw-inner">
    <div class="hiw-header">
      <span class="eyebrow">How It Works End to End</span>
      <h2 class="section-title">Seven Steps, Fully Automated</h2>
      <p class="section-sub">
        Every inbound call runs through this flow — no human in the loop required.
      </p>
    </div>

    <div class="steps-list">
      {steps.map((step, i) => (
        <div class="step-row">
          <div class="step-left">
            <div class="step-num">{step.number}</div>
            {i < steps.length - 1 && <div class="step-line" />}
          </div>
          <div class="step-body">
            <h3 class="step-title">{step.title}</h3>
            <p class="step-desc">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .hiw {
    background: var(--light);
    padding: 96px 2rem;
    border-bottom: 1px solid var(--border);
  }

  .hiw-inner {
    max-width: 820px;
    margin: 0 auto;
  }

  .hiw-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .eyebrow {
    display: inline-block;
    font-size: 0.73rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.13em;
    color: var(--blue);
    margin-bottom: 0.85rem;
  }

  .section-title {
    font-size: clamp(1.6rem, 2.5vw, 2.2rem);
    font-weight: 900;
    color: var(--navy);
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 0.75rem;
  }

  .section-sub {
    font-size: 1rem;
    color: var(--gray);
    line-height: 1.7;
  }

  /* Vertical step list */
  .steps-list {
    display: flex;
    flex-direction: column;
  }

  .step-row {
    display: flex;
    gap: 1.75rem;
  }

  .step-left {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
  }

  .step-num {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: linear-gradient(135deg, var(--navy) 0%, var(--blue) 100%);
    color: var(--sky);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  .step-line {
    width: 2px;
    flex: 1;
    background: linear-gradient(to bottom, var(--blue), transparent);
    margin: 4px 0;
    min-height: 28px;
    opacity: 0.25;
  }

  .step-body {
    padding-bottom: 2.25rem;
    padding-top: 0.6rem;
  }

  .step-row:last-child .step-body {
    padding-bottom: 0;
  }

  .step-title {
    font-size: 1rem;
    font-weight: 800;
    color: var(--navy);
    letter-spacing: -0.01em;
    margin-bottom: 0.4rem;
  }

  .step-desc {
    font-size: 0.925rem;
    color: var(--gray);
    line-height: 1.7;
  }

  @media (max-width: 640px) {
    .hiw { padding: 64px 1.5rem; }
    .step-num { width: 40px; height: 40px; }
  }
</style>
