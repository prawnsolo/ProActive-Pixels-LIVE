---
const niches = [
  'Roofing',
  'HVAC',
  'Plumbing',
  'Pest control',
  'Lawn care',
  'Electrical',
  'Cleaning',
  'Auto repair',
  'Med spa / Aesthetics',
  'Other / not listed',
];

const WORKER_URL = 'https://your-worker.workers.dev/submit';
---

<section class="form-section" id="form">
  <div class="form-inner">
    <div class="form-left">
      <span class="eyebrow">Get Started</span>
      <h2 class="section-title">Fill Out the Form.<br />Then Call Alex.</h2>
      <p class="form-desc">
        Enter your first name, business type, and the phone number you'll be
        calling from. After you submit, Alex's Retell phone number will appear
        on the next screen.
      </p>
      <p class="form-desc">
        Use the same number you'll call from — that's how the system identifies
        you and routes your call to the right agent.
      </p>
    </div>

    <div class="form-right">
      <div class="form-card">
        <form id="lead-form" novalidate>

          <div class="field-group">
            <label for="first_name" class="field-label">First Name</label>
            <input
              type="text"
              id="first_name"
              name="first_name"
              class="field-input"
              placeholder="e.g. Sarah"
              autocomplete="given-name"
              required
            />
            <span class="field-error" id="err-name"></span>
          </div>

          <div class="field-group">
            <label for="niche" class="field-label">Business Type</label>
            <div class="select-wrap">
              <select id="niche" name="niche" class="field-input field-select" required>
                <option value="" disabled selected>Select your industry…</option>
                {niches.map((n) => (
                  <option value={n}>{n}</option>
                ))}
              </select>
              <svg class="select-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <span class="field-error" id="err-niche"></span>
          </div>

          <div class="field-group">
            <label for="phone" class="field-label">Phone Number</label>
            <input
              type="tel"
              id="phone"
              name="phone"
              class="field-input"
              placeholder="(555) 000-0000"
              autocomplete="tel"
              required
            />
            <p class="field-hint">
              Use the same number you'll call from. This is how Alex identifies you.
            </p>
            <span class="field-error" id="err-phone"></span>
          </div>

          <div id="form-error" class="form-error-banner" style="display:none;"></div>

          <button type="submit" class="submit-btn" id="submit-btn">
            <span id="btn-text">Submit &amp; Get Alex's Number</span>
            <svg id="btn-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <svg id="btn-spinner" class="spinner" style="display:none;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <circle cx="12" cy="12" r="10" stroke-opacity="0.25"/>
              <path d="M22 12a10 10 0 01-10 10" stroke-linecap="round"/>
            </svg>
          </button>
        </form>

        <p class="form-privacy">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0110 0v4" stroke-linecap="round"/>
          </svg>
          Your information is used only to route your call to Alex. Never sold or shared.
        </p>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ WORKER_URL }}>
  const form = document.getElementById('lead-form');
  const submitBtn = document.getElementById('submit-btn');
  const btnText = document.getElementById('btn-text');
  const btnArrow = document.getElementById('btn-arrow');
  const btnSpinner = document.getElementById('btn-spinner');
  const formError = document.getElementById('form-error');

  function clearErrors() {
    ['err-name', 'err-niche', 'err-phone'].forEach((id) => {
      document.getElementById(id).textContent = '';
    });
    formError.style.display = 'none';
  }

  function showError(id, msg) {
    document.getElementById(id).textContent = msg;
  }

  function setLoading(loading) {
    submitBtn.disabled = loading;
    btnText.textContent = loading ? 'Submitting…' : "Submit & Get Alex's Number";
    btnArrow.style.display = loading ? 'none' : '';
    btnSpinner.style.display = loading ? '' : 'none';
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    clearErrors();

    const firstName = form.first_name.value.trim();
    const niche = form.niche.value;
    const phone = form.phone.value.trim();

    let valid = true;
    if (!firstName) { showError('err-name', 'First name is required.'); valid = false; }
    if (!niche) { showError('err-niche', 'Please select your business type.'); valid = false; }
    if (!phone) { showError('err-phone', 'Phone number is required.'); valid = false; }
    if (!valid) return;

    setLoading(true);

    try {
      const res = await fetch(WORKER_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ first_name: firstName, niche, phone }),
      });

      if (res.ok) {
        window.location.href = `/thank-you?name=${encodeURIComponent(firstName)}`;
      } else {
        const data = await res.json().catch(() => ({}));
        formError.textContent = data.error || 'Something went wrong. Please try again.';
        formError.style.display = 'block';
        setLoading(false);
      }
    } catch {
      formError.textContent = 'Could not connect. Please check your internet and try again.';
      formError.style.display = 'block';
      setLoading(false);
    }
  });
</script>

<style>
  .form-section {
    background: linear-gradient(180deg, var(--navy) 0%, #0F2347 100%);
    padding: 96px 2rem;
  }

  .form-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .eyebrow {
    display: inline-block;
    font-size: 0.73rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.13em;
    color: var(--sky);
    margin-bottom: 0.85rem;
  }

  .section-title {
    font-size: clamp(1.6rem, 2.5vw, 2.2rem);
    font-weight: 900;
    color: var(--white);
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 1.25rem;
  }

  .form-desc {
    font-size: 0.975rem;
    color: rgba(255,255,255,0.65);
    line-height: 1.75;
    margin-bottom: 0.9rem;
  }

  .form-desc:last-child { margin-bottom: 0; }

  /* Card */
  .form-card {
    background: var(--white);
    border-radius: 20px;
    padding: 2.5rem;
    box-shadow: 0 32px 80px rgba(0,0,0,0.35), 0 0 0 1px rgba(91,188,232,0.12);
  }

  .field-group { margin-bottom: 1.4rem; }

  .field-label {
    display: block;
    font-size: 0.83rem;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 0.45rem;
    letter-spacing: 0.01em;
  }

  .field-input {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1.5px solid var(--border);
    border-radius: 8px;
    font-size: 0.95rem;
    font-family: inherit;
    color: var(--text);
    background: var(--white);
    transition: border-color 0.15s, box-shadow 0.15s;
    outline: none;
    appearance: none;
  }

  .field-input:focus {
    border-color: var(--blue);
    box-shadow: 0 0 0 3px rgba(33,120,180,0.12);
  }

  .field-input::placeholder { color: #94A3B8; }

  .select-wrap { position: relative; }

  .field-select { cursor: pointer; padding-right: 2.5rem; }

  .select-arrow {
    position: absolute;
    right: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    width: 18px;
    height: 18px;
    color: var(--gray);
    pointer-events: none;
  }

  .field-hint {
    margin-top: 0.35rem;
    font-size: 0.77rem;
    color: var(--gray);
    line-height: 1.5;
  }

  .field-error {
    display: block;
    font-size: 0.77rem;
    color: #DC2626;
    margin-top: 0.3rem;
    font-weight: 500;
    min-height: 1rem;
  }

  .form-error-banner {
    background: #FEF2F2;
    border: 1px solid #FECACA;
    color: #B91C1C;
    border-radius: 8px;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    margin-bottom: 1rem;
    font-weight: 500;
  }

  .submit-btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    background: linear-gradient(135deg, var(--blue) 0%, var(--navy) 100%);
    color: var(--white);
    font-weight: 800;
    font-size: 1rem;
    padding: 1rem;
    border-radius: 10px;
    border: none;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.15s, box-shadow 0.2s;
    box-shadow: 0 4px 20px rgba(27,58,110,0.4);
    letter-spacing: -0.01em;
    margin-top: 0.5rem;
  }

  .submit-btn:hover:not(:disabled) {
    opacity: 0.9;
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(27,58,110,0.5);
  }

  .submit-btn:disabled { opacity: 0.7; cursor: not-allowed; }

  .spinner { animation: spin 0.8s linear infinite; }

  @keyframes spin { to { transform: rotate(360deg); } }

  .form-privacy {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.74rem;
    color: var(--gray);
    margin-top: 1rem;
    justify-content: center;
  }

  @media (max-width: 900px) {
    .form-inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .form-left { text-align: center; }
  }

  @media (max-width: 640px) {
    .form-section { padding: 64px 1.5rem; }
    .form-card { padding: 1.75rem; }
  }
</style>
