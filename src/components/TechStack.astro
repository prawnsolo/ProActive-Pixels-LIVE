---
const stack = [
  {
    name: 'Cloudflare Workers',
    role: 'Middleware & Routing',
    description:
      'Serverless edge functions that receive form submissions and Retell webhooks. No persistent server — always-on, globally distributed.',
    color: '#F6821F',
    icon: `<svg viewBox="0 0 128 128" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M89.5 80.2c.4-1.5.3-2.9-.5-3.9-.7-.9-1.9-1.4-3.4-1.5l-44.9-.6c-.3 0-.6-.2-.7-.4-.2-.2-.2-.5-.1-.8.2-.5.7-.8 1.2-.8l45.3-.6c5.4-.3 11.2-4.6 13.2-9.9l2.6-6.6c.1-.3.1-.6 0-.9C99.5 41.2 87.1 32 72.4 32c-13.7 0-25.4 8.3-30.4 20.3-2.8-2-6.3-3.1-10.1-2.7-7 .7-12.6 6.4-13.2 13.4-.2 1.8 0 3.5.4 5.1C11.7 68.9 6 75.1 6 82.6c0 .5 0 .9.1 1.4 0 .3.2.5.5.5H87.5c.5 0 1-.4 1.1-.9l.9-3.4z" fill="#F6821F"/>
      <path d="M100.6 53.5c-.4 0-.7 0-1.1.1-.2 0-.4.2-.5.4L97.6 58c-.4 1.5-.3 2.9.5 3.9.7.9 1.9 1.4 3.4 1.5l9.6.6c.3 0 .6.2.7.4.2.2.2.5.1.8-.2.5-.7.8-1.2.8l-9.9.6c-5.4.3-11.2 4.6-13.2 9.9l-.7 1.8c-.1.3.1.6.4.6H121c.3 0 .5-.2.6-.5.4-1.7.6-3.5.6-5.3 0-10.4-8.5-18.9-21.6-18.8z" fill="#FBAD41"/>
    </svg>`,
  },
  {
    name: 'Supabase',
    role: 'Database',
    description:
      'Postgres database storing form submissions. Every inbound call triggers a real-time lookup against phone numbers in E.164 format.',
    color: '#3ECF8E',
    icon: `<svg viewBox="0 0 109 113" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M63.7 110.3c-2.5 3.1-7.6 1.4-7.8-2.5L52.7 7.2h42.7c7.7 0 12 9 7.3 14.9L63.7 110.3z" fill="url(#sg1)"/>
      <path d="M63.7 110.3c-2.5 3.1-7.6 1.4-7.8-2.5L52.7 7.2h42.7c7.7 0 12 9 7.3 14.9L63.7 110.3z" fill="url(#sg2)" fill-opacity="0.2"/>
      <path d="M45.3 2.7c2.5-3.1 7.6-1.4 7.8 2.5l2.9 100.6H13.3c-7.7 0-12-9-7.3-14.9L45.3 2.7z" fill="#3ECF8E"/>
      <defs>
        <linearGradient id="sg1" x1="53" y1="7" x2="83" y2="111" gradientUnits="userSpaceOnUse">
          <stop stop-color="#249361"/>
          <stop offset="1" stop-color="#3ECF8E"/>
        </linearGradient>
        <linearGradient id="sg2" x1="36" y1="0" x2="54" y2="58" gradientUnits="userSpaceOnUse">
          <stop stop-color="white"/>
          <stop offset="1" stop-color="white" stop-opacity="0"/>
        </linearGradient>
      </defs>
    </svg>`,
  },
  {
    name: 'Retell AI',
    role: 'Voice AI Platform',
    description:
      'Hosts all 10 agents (9 niche-specific + 1 intake fallback). Fires the inbound webhook and receives the routing response with the dynamic caller variables.',
    color: '#5BBCE8',
    icon: `<svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect width="64" height="64" rx="14" fill="#1B3A6E"/>
      <path d="M20 44V20l16 8-16 16z" fill="#5BBCE8"/>
      <rect x="38" y="20" width="6" height="24" rx="3" fill="#2178B4"/>
    </svg>`,
  },
];
---

<section class="tech" id="tech-stack">
  <div class="tech-inner">
    <div class="tech-header">
      <span class="section-eyebrow">Under the Hood</span>
      <h2 class="section-title">Built on Infrastructure That Doesn't Blink</h2>
      <p class="section-sub">
        Three best-in-class tools, wired together so tightly that the entire
        routing decision happens before your caller hears a ring tone.
      </p>
    </div>

    <div class="tech-grid">
      {stack.map((item) => (
        <div class="tech-card">
          <div class="tech-logo" set:html={item.icon} />
          <div class="tech-label" style={`color: ${item.color}`}>{item.role}</div>
          <h3 class="tech-name">{item.name}</h3>
          <p class="tech-desc">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .tech {
    background: var(--light);
    padding: 96px 2rem;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .tech-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .tech-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .section-eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--blue);
    margin-bottom: 0.75rem;
  }

  .section-title {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 900;
    color: var(--navy);
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .section-sub {
    font-size: 1.05rem;
    color: var(--gray);
    line-height: 1.7;
    max-width: 560px;
    margin: 0 auto;
  }

  .tech-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .tech-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .tech-card:hover {
    box-shadow: 0 8px 32px rgba(27, 58, 110, 0.1);
    transform: translateY(-3px);
  }

  .tech-logo {
    width: 52px;
    height: 52px;
    margin-bottom: 1.25rem;
  }

  .tech-logo svg {
    width: 100%;
    height: 100%;
  }

  .tech-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.4rem;
  }

  .tech-name {
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--navy);
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
  }

  .tech-desc {
    font-size: 0.9rem;
    color: var(--gray);
    line-height: 1.65;
  }

  @media (max-width: 768px) {
    .tech-grid {
      grid-template-columns: 1fr;
    }

    .tech {
      padding: 64px 1.5rem;
    }
  }
</style>
