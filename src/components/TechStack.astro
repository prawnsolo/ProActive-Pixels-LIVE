---
const stack = [
  {
    name: 'Cloudflare Workers',
    description:
      'Hosts the two-route middleware. Serverless, fast, no persistent server needed.',
    color: '#F6821F',
  },
  {
    name: 'Supabase',
    description:
      'Postgres database that stores form submissions. The Worker queries it on every inbound call.',
    color: '#3ECF8E',
  },
  {
    name: 'Retell AI',
    description:
      'The voice AI platform. Hosts all agents. Fires the inbound webhook. Receives the routing response.',
    color: 'var(--sky)',
  },
  {
    name: 'HTML Form',
    description:
      'On the landing page, posts directly to the Worker\'s /submit endpoint.',
    color: 'var(--blue)',
  },
];
---

<section class="tech" id="tech-stack">
  <div class="tech-inner">
    <div class="tech-header">
      <span class="eyebrow">Tech Stack</span>
      <h2 class="section-title">Four Pieces. One Tight Loop.</h2>
    </div>

    <div class="tech-grid">
      {stack.map((item) => (
        <div class="tech-card">
          <div class="tech-dot" style={`background: ${item.color}`}></div>
          <h3 class="tech-name">{item.name}</h3>
          <p class="tech-desc">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .tech {
    background: var(--white);
    padding: 96px 2rem;
    border-bottom: 1px solid var(--border);
  }

  .tech-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .tech-header {
    margin-bottom: 3rem;
  }

  .eyebrow {
    display: inline-block;
    font-size: 0.73rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.13em;
    color: var(--blue);
    margin-bottom: 0.85rem;
  }

  .section-title {
    font-size: clamp(1.6rem, 2.5vw, 2.2rem);
    font-weight: 900;
    color: var(--navy);
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .tech-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  .tech-card {
    background: var(--light);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.75rem;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .tech-card:hover {
    box-shadow: 0 6px 24px rgba(27,58,110,0.09);
    transform: translateY(-2px);
  }

  .tech-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    margin-bottom: 1rem;
  }

  .tech-name {
    font-size: 0.975rem;
    font-weight: 800;
    color: var(--navy);
    letter-spacing: -0.01em;
    margin-bottom: 0.6rem;
  }

  .tech-desc {
    font-size: 0.875rem;
    color: var(--gray);
    line-height: 1.65;
  }

  @media (max-width: 900px) {
    .tech-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 540px) {
    .tech { padding: 64px 1.5rem; }
    .tech-grid { grid-template-columns: 1fr; }
  }
</style>
