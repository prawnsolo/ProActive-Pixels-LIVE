---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__inner">
    <p class="footer__legal">
      By submitting this form you agree to receive a phone number to call Alex, our AI voice
      assistant, for your free business assessment. Your information will never be sold or shared
      with third parties. Results described on this page represent potential opportunities
      identified through our assessment process and are not guaranteed outcomes. Individual results
      will vary based on business type, size, and implementation.
    </p>
    <p class="footer__copy">
      &copy; {year} Proactive Pixels LLC. All rights reserved.
      <span class="footer__sep">|</span>
      <a href="/privacy" class="footer__link">Privacy Policy</a>
    </p>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-bg-dark);
    padding: 40px 24px;
  }

  .footer__inner {
    max-width: var(--max-content);
    margin: 0 auto;
    text-align: center;
  }

  .footer__legal {
    font-size: 11px;
    color: #6B7280;
    line-height: 1.7;
    margin-bottom: 16px;
  }

  .footer__copy {
    font-size: 12px;
    color: #6B7280;
  }

  .footer__sep {
    margin: 0 8px;
    opacity: 0.4;
  }

  .footer__link {
    color: #9CA3AF;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer__link:hover {
    color: white;
  }
</style>
