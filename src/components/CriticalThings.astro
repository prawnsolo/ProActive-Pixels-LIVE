---
const criticals = [
  {
    number: '01',
    title: 'Phone Format Mismatch',
    description:
      'The form must normalize to E.164 before saving. The webhook handler must normalize before querying. If one sends 5551234567 and the other sends +15551234567, the lookup returns nothing and every caller hits the fallback.',
  },
  {
    number: '02',
    title: 'Niche Strings Must Match Exactly',
    description:
      'The string saved from the form must be byte-for-byte identical to the keys in the routing table. "Pest control" and "Pest Control" are different strings. Pick one casing and enforce it everywhere.',
  },
  {
    number: '03',
    title: 'Agent IDs Must Exist in Retell Before Deployment',
    description:
      'Create all 10 agents in Retell first. Copy their IDs into the routing table. Deploy after.',
  },
  {
    number: '04',
    title: 'Retell Webhook Must Be Pointed at the Worker URL',
    description:
      'In the Retell dashboard, set the inbound webhook URL to your deployed Worker. Without this, Retell never calls your system and every call gets a generic agent.',
  },
];
---

<section class="critical" id="critical-things">
  <div class="critical-inner">
    <div class="critical-header">
      <span class="eyebrow">Critical Things That Will Break This If Wrong</span>
      <h2 class="section-title">Four Ways to Break It.<br />Don't Do Any of Them.</h2>
    </div>

    <div class="critical-grid">
      {criticals.map((item) => (
        <div class="critical-card">
          <div class="critical-num">{item.number}</div>
          <h3 class="critical-title">{item.title}</h3>
          <p class="critical-desc">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .critical {
    background: var(--navy);
    padding: 96px 2rem;
  }

  .critical-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .critical-header {
    margin-bottom: 3rem;
  }

  .eyebrow {
    display: inline-block;
    font-size: 0.73rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.13em;
    color: var(--sky);
    margin-bottom: 0.85rem;
  }

  .section-title {
    font-size: clamp(1.6rem, 2.5vw, 2.2rem);
    font-weight: 900;
    color: var(--white);
    letter-spacing: -0.03em;
    line-height: 1.15;
  }

  .critical-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .critical-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(91,188,232,0.15);
    border-radius: 14px;
    padding: 1.75rem;
    transition: border-color 0.2s, background 0.2s;
  }

  .critical-card:hover {
    border-color: rgba(91,188,232,0.35);
    background: rgba(255,255,255,0.06);
  }

  .critical-num {
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    color: var(--sky);
    margin-bottom: 0.75rem;
    text-transform: uppercase;
  }

  .critical-title {
    font-size: 1rem;
    font-weight: 800;
    color: var(--white);
    letter-spacing: -0.01em;
    margin-bottom: 0.6rem;
    line-height: 1.3;
  }

  .critical-desc {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .critical-grid { grid-template-columns: 1fr; }
    .critical { padding: 64px 1.5rem; }
  }
</style>
