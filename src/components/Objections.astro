---
const objections = [
  {
    quote: '"Is this actually for me?"',
    answer:
      "If you're still in the idea stage, this isn't for you yet. Come back when you have customers, payroll, and a few months of wondering where the money went.",
  },
  {
    quote: '"AI probably isn\'t relevant to my business."',
    answer:
      "Most owners say that. Most owners are wrong. The report shows you exactly which parts of your operation are bleeding money on tasks a $50/month tool could handle today.",
  },
  {
    quote: '"This is probably just a sales pitch."',
    answer:
      "The report is yours whether you work with us or not. No follow-up call unless you want one. No invoice. Read it, hand it to whoever you want, or ignore it. We're fine either way.",
  },
  {
    quote: '"I don\'t know enough about this stuff."',
    answer:
      "You don't need to. That's the point. You answer 8 questions about how your business runs. We figure out the rest and hand you a plain-English report with a ranked list of fixes.",
  },
];
---

<section class="objections">
  <div class="objections__inner">
    <h2 class="objections__heading">We've heard these.</h2>
    {
      objections.map((item, i) => (
        <div class={`objection fade-in fade-in-delay-${i + 1}`}>
          <p class="objection__quote">{item.quote}</p>
          <p class="objection__answer">{item.answer}</p>
        </div>
      ))
    }

    <div class="objections__cta fade-in fade-in-delay-3">
      <a href="#form" class="btn btn--primary">
        Show Me What My Business Is Losing
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M3.75 9h10.5M9.75 4.5L14.25 9l-4.5 4.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .objections {
    padding: 80px 24px 100px;
    background: var(--color-bg);
  }

  .objections__inner {
    max-width: var(--max-content);
    margin: 0 auto;
  }

  .objections__heading {
    font-size: clamp(22px, 3vw, 28px);
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.01em;
    margin-bottom: 40px;
    text-wrap: balance;
  }

  .objection {
    padding-top: 40px;
    margin-bottom: 0;
  }

  .objection + .objection {
    border-top: 1px solid var(--color-border);
  }

  .objections__inner > .objection:first-child {
    padding-top: 0;
  }

  .objection:last-of-type {
    margin-bottom: 0;
  }

  .objection__quote {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: 10px;
    line-height: 1.5;
  }

  .objection__answer {
    font-size: 16px;
    color: var(--color-body);
    line-height: 1.75;
  }

  .objections__cta {
    margin-top: 60px;
    display: flex;
    justify-content: center;
  }

  @media (max-width: 600px) {
    .objections__cta .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
