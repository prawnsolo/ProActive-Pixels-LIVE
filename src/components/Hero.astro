---
---

<section class="hero">
  <div class="hero__inner">

    <h1 class="hero__headline">
      <span class="hero__kicker">12 minutes.</span>
      <span class="hero__tagline">
        That's how long it takes to find the
        <span class="hero__amount">$20,000 to $60,000</span>
        your business is losing every year.
      </span>
    </h1>

    <p class="hero__subheadline">
      Free call. Written report within 24 hours. Every leak named, priced, and ranked by what to fix first.
    </p>

    <div class="hero__trust">
      <span class="hero__trust-item">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <circle cx="7" cy="7" r="7" fill="#171E62" opacity="0.14"/>
          <path d="M4 7l2 2 4-4" stroke="#171E62" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        No pitch
      </span>
      <span class="hero__trust-item">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <circle cx="7" cy="7" r="7" fill="#171E62" opacity="0.14"/>
          <path d="M4 7l2 2 4-4" stroke="#171E62" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        No obligation
      </span>
      <span class="hero__trust-item">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <circle cx="7" cy="7" r="7" fill="#171E62" opacity="0.14"/>
          <path d="M4 7l2 2 4-4" stroke="#171E62" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        You keep the report either way
      </span>
    </div>

    <a href="#form" class="btn btn--primary hero__cta">
      Show Me What My Business Is Losing
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <path d="M3.75 9h10.5M9.75 4.5L14.25 9l-4.5 4.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>

  </div>
</section>

<style>
  .hero {
    background-color: var(--color-bg);
    padding: 88px 24px 96px;
    text-align: center;
  }

  .hero__inner {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* ===========================
     HEADLINE — two-part layout
  =========================== */
  .hero__headline {
    font-family: var(--font-body);
    margin-bottom: 32px;
    letter-spacing: -0.02em;
  }

  /* "12 minutes." — large display number */
  .hero__kicker {
    display: block;
    font-size: clamp(64px, 10vw, 96px);
    font-weight: 700;
    color: var(--color-text);
    line-height: 1;
    letter-spacing: -0.035em;
    margin-bottom: 32px;
  }

  /* "That's how long it takes to find the…" */
  .hero__tagline {
    display: block;
    font-size: clamp(20px, 2.8vw, 28px);
    font-weight: 400;
    color: var(--color-text-light);
    line-height: 1.45;
    max-width: 640px;
    margin: 0 auto;
  }

  .hero__amount {
    color: var(--color-highlight);
    font-weight: 700;
  }

  /* ===========================
     SUBHEADLINE
  =========================== */
  .hero__subheadline {
    font-size: 18px;
    font-weight: 400;
    color: var(--color-body);
    line-height: 1.65;
    margin-bottom: 28px;
    max-width: 560px;
  }

  /* ===========================
     TRUST ITEMS
  =========================== */
  .hero__trust {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    margin-bottom: 40px;
    justify-content: center;
  }

  .hero__trust-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-muted);
  }

  /* ===========================
     CTA
  =========================== */
  .hero__cta {
    font-size: 17px;
    min-width: 280px;
  }

  /* ===========================
     RESPONSIVE
  =========================== */
  @media (max-width: 640px) {
    .hero {
      padding: 64px 20px 72px;
    }

    .hero__kicker {
      font-size: clamp(52px, 15vw, 80px);
      margin-bottom: 24px;
    }

    .hero__tagline {
      font-size: clamp(18px, 5vw, 22px);
    }

    .hero__cta {
      width: 100%;
      justify-content: center;
    }
  }
</style>
