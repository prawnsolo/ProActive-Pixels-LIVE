---
---

<section class="hero">
  <div class="hero__inner">
    <div class="hero__content">
      <div class="hero__eyebrow">Free Business Assessment</div>

      <h1 class="hero__headline">
        12 minutes.<br />
        <span class="hero__headline-rest">That's how long it takes to find the</span>
        <span class="hero__amount">$20,000 to $60,000</span>
        <span class="hero__headline-rest"> your business is losing every year.</span>
      </h1>

      <p class="hero__subheadline">
        Free call. Written report within 24 hours. Every leak named, priced, and ranked by what to fix first.
      </p>

      <div class="hero__trust">
        <span class="hero__trust-item">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <circle cx="7" cy="7" r="7" fill="#1B3A5C" opacity="0.12"/>
            <path d="M4 7l2 2 4-4" stroke="#1B3A5C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          No pitch
        </span>
        <span class="hero__trust-item">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <circle cx="7" cy="7" r="7" fill="#1B3A5C" opacity="0.12"/>
            <path d="M4 7l2 2 4-4" stroke="#1B3A5C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          No obligation
        </span>
        <span class="hero__trust-item">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <circle cx="7" cy="7" r="7" fill="#1B3A5C" opacity="0.12"/>
            <path d="M4 7l2 2 4-4" stroke="#1B3A5C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          You keep the report either way
        </span>
      </div>

      <a href="#form" class="btn btn--primary hero__cta">
        Show Me What My Business Is Losing
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M3.75 9h10.5M9.75 4.5L14.25 9l-4.5 4.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <div class="hero__image-wrap">
      <div class="hero__image-badge">
        <span class="hero__badge-number">$43,200</span>
        <span class="hero__badge-label">found in one assessment</span>
      </div>
      <img
        src="/images/hero-jose.png"
        alt="Jose pointing at AI & Automation Opportunity Report on laptop screen"
        class="hero__image"
        width="520"
        height="560"
        loading="eager"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    background-color: var(--color-bg);
    padding: 64px 24px 80px;
    overflow: hidden;
  }

  .hero__inner {
    max-width: var(--max-hero);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .hero__eyebrow {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-navy);
    background: rgba(27, 58, 92, 0.08);
    padding: 6px 14px;
    border-radius: 100px;
    margin-bottom: 20px;
  }

  .hero__headline {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 58px);
    font-weight: 700;
    line-height: 1.1;
    color: var(--color-text);
    margin-bottom: 20px;
    letter-spacing: -0.02em;
  }

  .hero__headline-rest {
    font-weight: 400;
    font-style: italic;
  }

  .hero__amount {
    color: var(--color-amber);
    font-weight: 900;
    font-style: normal;
    position: relative;
    white-space: nowrap;
  }

  .hero__subheadline {
    font-size: 19px;
    font-weight: 400;
    color: var(--color-text-light);
    line-height: 1.6;
    margin-bottom: 16px;
    max-width: 480px;
  }

  .hero__trust {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 32px;
  }

  .hero__trust-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    color: var(--color-muted);
    font-weight: 500;
  }

  /* ===========================
     CTA BUTTON
  =========================== */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 600;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: all 0.2s ease;
    padding: 18px 32px;
    border-radius: var(--radius-sm);
  }

  .btn--primary {
    background: var(--color-navy);
    color: white;
    box-shadow: var(--shadow-btn);
  }

  .btn--primary:hover {
    background: var(--color-navy-hover);
    box-shadow: var(--shadow-btn-hover);
    transform: translateY(-1px);
  }

  .btn--primary:active {
    transform: translateY(0);
  }

  .hero__cta {
    width: 100%;
    justify-content: center;
    max-width: 420px;
  }

  /* ===========================
     HERO IMAGE
  =========================== */
  .hero__image-wrap {
    position: relative;
  }

  .hero__image {
    width: 100%;
    max-width: 520px;
    border-radius: var(--radius-md);
    box-shadow: 0 20px 60px rgba(27, 58, 92, 0.15);
    margin-left: auto;
    object-fit: cover;
  }

  .hero__image-badge {
    position: absolute;
    bottom: 32px;
    left: -20px;
    background: white;
    border-radius: var(--radius-md);
    padding: 14px 20px;
    box-shadow: var(--shadow-card);
    border: 1px solid var(--color-border);
    z-index: 2;
    animation: float 4s ease-in-out infinite;
  }

  .hero__badge-number {
    display: block;
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    color: var(--color-amber);
    line-height: 1.1;
  }

  .hero__badge-label {
    display: block;
    font-size: 12px;
    color: var(--color-muted);
    margin-top: 2px;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  /* ===========================
     RESPONSIVE
  =========================== */
  @media (max-width: 768px) {
    .hero {
      padding: 40px 20px 60px;
    }

    .hero__inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .hero__image-wrap {
      order: -1;
    }

    .hero__image {
      max-width: 100%;
      margin: 0 auto;
    }

    .hero__image-badge {
      left: 10px;
      bottom: 20px;
    }

    .hero__cta {
      max-width: 100%;
    }

    .hero__subheadline {
      font-size: 17px;
    }
  }
</style>
