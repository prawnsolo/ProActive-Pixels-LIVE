---
---

<section class="hero">
  <div class="hero__inner">

    <h1 class="hero__headline">
      <span class="hero__kicker">12&ensp;minutes</span>
      <span class="hero__tagline">
        That's how long it takes to find the
        <span class="hero__amount">$20,000 to $60,000</span>
        your business is losing every year.
      </span>
    </h1>

    <p class="hero__subheadline">
      Free call. Written report within 24 hours. Every leak named, priced, and ranked by what to fix first.
    </p>

    <div class="hero__trust">
      <span class="hero__trust-item">
        <svg class="hero__trust-icon" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <circle cx="7" cy="7" r="7" fill="currentColor" opacity="0.2"/>
          <path d="M4 7l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        No pitch
      </span>
      <span class="hero__trust-item">
        <svg class="hero__trust-icon" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <circle cx="7" cy="7" r="7" fill="currentColor" opacity="0.2"/>
          <path d="M4 7l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        No obligation
      </span>
      <span class="hero__trust-item">
        <svg class="hero__trust-icon" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <circle cx="7" cy="7" r="7" fill="currentColor" opacity="0.2"/>
          <path d="M4 7l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        You keep the report either way
      </span>
    </div>

    <a href="#form" class="btn btn--primary hero__cta">
      Show Me What My Business Is Losing
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <path d="M3.75 9h10.5M9.75 4.5L14.25 9l-4.5 4.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>

  </div>
</section>

<style>
  .hero {
    background-color: var(--color-bg);
    padding: 88px 24px 96px;
    text-align: center;
  }

  .hero__inner {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* ===========================
     HEADLINE — two-part layout
  =========================== */
  .hero__headline {
    font-family: var(--font-body);
    margin-bottom: 32px;
    letter-spacing: -0.02em;
  }

  /* DSEG14 Classic — 14-segment LCD digital clock font */
  @font-face {
    font-family: 'DSEG14Classic';
    src: url('https://cdn.jsdelivr.net/npm/dseg@0.46.0/fonts/DSEG14-Classic/DSEG14Classic-BoldItalic.woff2') format('woff2');
    font-weight: 700;
    font-style: italic;
    font-display: swap;
  }

  /* "12 minutes" — alarm-clock green LCD kicker */
  .hero__kicker {
    display: block;
    font-family: 'DSEG14Classic', 'Orbitron', monospace;
    font-style: italic;
    font-size: clamp(28px, 9vw, 80px);
    font-weight: 700;
    color: oklch(58% 0.22 145);
    text-shadow: 0 0 10px oklch(62% 0.24 145 / 0.3), 0 0 24px oklch(62% 0.24 145 / 0.12);
    line-height: 1.1;
    letter-spacing: 0;
    white-space: nowrap;
    margin: 0 0 28px -0.6em;
    padding: 0;
  }

  :global([data-theme="dark"]) .hero__kicker {
    color: oklch(70% 0.24 145);
    text-shadow: 0 0 12px oklch(70% 0.26 145 / 0.45), 0 0 30px oklch(70% 0.26 145 / 0.2);
  }

  /* "That's how long it takes to find the…" */
  .hero__tagline {
    display: block;
    font-size: clamp(20px, 2.8vw, 28px);
    font-weight: 400;
    color: var(--color-text-light);
    line-height: 1.45;
    max-width: 640px;
    margin: 0 auto;
    text-wrap: balance;
  }

  .hero__amount {
    color: var(--color-highlight);
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }

  /* ===========================
     SUBHEADLINE
  =========================== */
  .hero__subheadline {
    font-size: 18px;
    font-weight: 400;
    color: var(--color-body);
    line-height: 1.65;
    margin-bottom: 28px;
    max-width: 560px;
  }

  /* ===========================
     TRUST ITEMS
  =========================== */
  .hero__trust {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    margin-bottom: 40px;
    justify-content: center;
  }

  .hero__trust-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-muted);
  }

  .hero__trust-icon {
    color: oklch(58% 0.22 145);
    flex-shrink: 0;
  }

  :global([data-theme="dark"]) .hero__trust-icon {
    color: oklch(70% 0.24 145);
  }

  /* ===========================
     CTA
  =========================== */
  .hero__cta {
    font-size: 17px;
    min-width: 280px;
  }

  /* ===========================
     RESPONSIVE
  =========================== */
  @media (max-width: 640px) {
    .hero {
      padding: 64px 20px 72px;
    }

    .hero__tagline {
      font-size: clamp(18px, 5vw, 22px);
    }

    .hero__cta {
      width: 100%;
      justify-content: center;
    }
  }
</style>
