<script define:vars={{ formNicheValue }}>
  // Pre-select niche in dropdown
  const select = document.getElementById('business-type');
  if (select && formNicheValue) {
    select.value = formNicheValue;
  }

  // Theme toggle
  const toggle = document.getElementById('theme-toggle');
  function applyTheme(theme) {
    const isDark = theme === 'dark';
    if (isDark) {
      document.documentElement.setAttribute('data-theme', 'dark');
      toggle?.classList.add('is-dark');
      toggle?.setAttribute('aria-label', 'Switch to light mode');
    } else {
      document.documentElement.removeAttribute('data-theme');
      toggle?.classList.remove('is-dark');
      toggle?.setAttribute('aria-label', 'Switch to dark mode');
    }
    try { localStorage.setItem('pp-theme', theme); } catch (e) {}
  }
  if (document.documentElement.getAttribute('data-theme') === 'dark') {
    toggle?.classList.add('is-dark');
    toggle?.setAttribute('aria-label', 'Switch to light mode');
  }
  toggle?.addEventListener('click', () => {
    const isDark = toggle.classList.contains('is-dark');
    applyTheme(isDark ? 'light' : 'dark');
  });

  // Scroll fade-in
  const observer = new IntersectionObserver(
    (entries) => { entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } }); },
    { threshold: 0.1 }
  );
  document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));

  // Form logic
  const form = document.getElementById('leak-form');
  const formView = document.getElementById('form-view');
  const disclosureView = document.getElementById('disclosure-view');
  const submitBtn = document.getElementById('submit-btn');
  const btnText = document.getElementById('btn-text');
  const btnLoading = document.getElementById('btn-loading');
  const btnArrow = document.getElementById('btn-arrow');
  const apiError = document.getElementById('api-error');

  function validateField(id, validator) {
    const wrapper = document.getElementById(id);
    const valid = validator();
    if (!valid) { wrapper.classList.add('has-error'); }
    else { wrapper.classList.remove('has-error'); }
    return valid;
  }
  function isValidPhone(p) { return /^[\d\s\-\(\)\+]{7,15}$/.test(p.trim()); }
  function resetButton() {
    btnText.style.display = '';
    btnArrow.style.display = '';
    btnLoading.style.display = 'none';
    submitBtn.disabled = false;
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const firstName = document.getElementById('first-name').value.trim();
    const businessType = document.getElementById('business-type').value;
    const phone = document.getElementById('phone').value.trim();

    const nameOk = validateField('field-name', () => firstName.length > 0);
    const bizOk = validateField('field-business', () => businessType !== '');
    const phoneOk = validateField('field-phone', () => isValidPhone(phone));
    if (!nameOk || !bizOk || !phoneOk) return;

    apiError.style.display = 'none';
    btnText.style.display = 'none';
    btnArrow.style.display = 'none';
    btnLoading.style.display = 'flex';
    submitBtn.disabled = true;

    try {
      const res = await fetch('https://proactivepixels-router.aqua-noriega.workers.dev/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ first_name: firstName, niche: businessType, phone }),
      });
      if (!res.ok) { resetButton(); apiError.style.display = 'block'; return; }

      if (typeof window.gtag !== 'undefined') {
        window.gtag('event', 'form_submit', { event_category: 'Lead', event_label: businessType });
      }
      if (typeof window.fbq !== 'undefined') {
        window.fbq('track', 'Lead', { business_type: businessType });
      }

      formView.style.display = 'none';
      disclosureView.style.display = 'block';
      disclosureView.scrollIntoView({ behavior: 'smooth', block: 'center' });
    } catch (err) {
      resetButton();
      apiError.style.display = 'block';
    }
  });

  document.getElementById('first-name')?.addEventListener('blur', () => {
    validateField('field-name', () => document.getElementById('first-name').value.trim().length > 0);
  });
  document.getElementById('business-type')?.addEventListener('change', () => {
    validateField('field-business', () => document.getElementById('business-type').value !== '');
  });
  document.getElementById('phone')?.addEventListener('blur', () => {
    validateField('field-phone', () => isValidPhone(document.getElementById('phone').value.trim()));
  });
</script>
