---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  metaTitle: string;
  metaDescription: string;
  nicheLabel: string;
  lossRange: string;
  nicheValue: string;
  nicheOperator: string;
  objections?: Array<{ quote: string; answer: string }>;
}

const {
  metaTitle,
  metaDescription,
  nicheLabel,
  lossRange,
  nicheValue,
  nicheOperator,
  objections = [
    {
      quote: '"Is this actually for me?"',
      answer:
        "If you're still in the idea stage, this isn't for you yet. Come back when you have customers, payroll, and a few months of wondering where the money went.",
    },
    {
      quote: '"AI probably isn\'t relevant to my business."',
      answer:
        "Most owners say that. Most owners are wrong. The report shows you exactly which parts of your operation are bleeding money on tasks a $50/month tool could handle today.",
    },
    {
      quote: '"This is probably just a sales pitch."',
      answer:
        "The report is yours whether you work with us or not. No follow-up call unless you want one. No invoice. Read it, hand it to whoever you want, or ignore it. We're fine either way.",
    },
    {
      quote: '"I don\'t know enough about this stuff."',
      answer:
        "You don't need to. That's the point. You answer 8 questions about how your business runs. We figure out the rest and hand you a plain-English report with a ranked list of fixes.",
    },
  ],
} = Astro.props;
---

<BaseLayout title={metaTitle} description={metaDescription} noindex={true}>

  <!-- STICKY HEADER -->
  <header class="site-header">
    <div class="site-header__inner">
      <a href="/" class="site-logo" aria-label="ProActive Pixels home">
        <span class="logo-pro">Pro</span><span class="logo-active">Active</span><span class="logo-pixels">Pixels</span>
      </a>
      <button class="theme-toggle" id="theme-toggle" aria-label="Switch to dark mode">
        <svg class="toggle-icon toggle-icon--sun" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <path d="M12 2v2M12 20v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M2 12h2M20 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
        <span class="toggle-track"><span class="toggle-thumb"></span></span>
        <svg class="toggle-icon toggle-icon--moon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </header>

  <main>

    <!-- HERO -->
    <section class="hero">
      <div class="hero__inner">

        <h1 class="hero__headline">
          <span class="hero__kicker">12&ensp;minutes</span>
          <span class="hero__tagline">
            You're already losing
            <span class="hero__amount">{lossRange}</span>
            a year. One 12-minute call tells you exactly where.
          </span>
        </h1>

        <p class="hero__subheadline">
          Free call. Written report within 24 hours. Every leak named, priced, and ranked by priority.
        </p>

        <div class="hero__trust">
          <span class="hero__trust-item">
            <svg class="hero__trust-icon" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <circle cx="7" cy="7" r="7" fill="currentColor" opacity="0.2"/>
              <path d="M4 7l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            No pitch
          </span>
          <span class="hero__trust-item">
            <svg class="hero__trust-icon" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <circle cx="7" cy="7" r="7" fill="currentColor" opacity="0.2"/>
              <path d="M4 7l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            No obligation
          </span>
          <span class="hero__trust-item">
            <svg class="hero__trust-icon" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <circle cx="7" cy="7" r="7" fill="currentColor" opacity="0.2"/>
              <path d="M4 7l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            You keep the report either way
          </span>
        </div>

        <a href="#form" class="btn btn--primary hero__cta">
          Show Me What My Business Is Losing
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <path d="M3.75 9h10.5M9.75 4.5L14.25 9l-4.5 4.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>

      </div>
    </section>

    <!-- WHY FREE -->
    <section class="why-free" id="why-free">
      <div class="why-free__inner">

        <h2 class="why-free__heading">Why is this free?</h2>

        <p class="why-free__body">
          Because we're early. We built the assessment and the report. We haven't run it for 100 {nicheOperator} yet. We're running it for the first ones now, so we can measure what we said would happen against what actually happens, build the case studies, and earn the right to charge for it later.
        </p>

        <p class="why-free__body">
          In exchange for your 12 minutes, you get a written report that tells you specifically what's costing you the most in your business right now, with a dollar number next to each item.
        </p>

        <p class="why-free__roi">
          <em>If even one of those turns out to be right, the 12 minutes was worth it.</em>
        </p>

        <p class="why-free__closing">
          No pitch on the call. If you want to know what it would cost to fix something we found, ask. We'll tell you. The report is yours to keep, share, or ignore. No follow-up unless you want one. That's not a policy. That's the deal.
        </p>

        <div class="why-free__anchor">
          <div class="why-free__anchor-row">
            <span class="why-free__anchor-label">What a consultant charges for this</span>
            <span class="why-free__anchor-price">$1,500 – $3,000</span>
          </div>
          <div class="why-free__anchor-row why-free__anchor-row--you">
            <span class="why-free__anchor-label">What you pay</span>
            <span class="why-free__anchor-free">12 minutes</span>
          </div>
        </div>

      </div>
    </section>

    <!-- OBJECTIONS -->
    <section class="objections">
      <div class="objections__inner">
        <h2 class="objections__heading">We've heard these.</h2>
        {
          objections.map((item, i) => (
            <div class={`objection fade-in fade-in-delay-${i + 1}`}>
              <p class="objection__quote">{item.quote}</p>
              <p class="objection__answer">{item.answer}</p>
            </div>
          ))
        }
        <div class="objections__cta fade-in fade-in-delay-3">
          <a href="#form" class="btn btn--primary">
            Show Me What My Business Is Losing
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M3.75 9h10.5M9.75 4.5L14.25 9l-4.5 4.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- FORM -->
    <section class="form-section" id="form">
      <div class="form-section__inner">

        <div class="form-card" id="form-card">
          <div id="form-view">
            <h2 class="form-card__headline">Ready to see the number?</h2>
            <p class="form-card__sub">Three fields. We'll walk you through exactly what happens next.</p>

            <form id="leak-form" novalidate>
              <!-- NAME -->
              <div class="form-field" id="field-name">
                <label for="first-name" class="form-label">First Name</label>
                <input
                  type="text"
                  id="first-name"
                  name="first_name"
                  class="form-input"
                  placeholder="Your first name"
                  autocomplete="given-name"
                  required
                />
                <span class="form-error" id="error-name">Please enter your first name.</span>
              </div>

              <!-- EMAIL (replaces industry dropdown) -->
              <div class="form-field" id="field-email">
                <label for="email" class="form-label">Email Address</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  class="form-input"
                  placeholder="you@yourbusiness.com"
                  autocomplete="email"
                  required
                />
                <span class="form-error" id="error-email">Please enter a valid email address.</span>
              </div>

              <!-- PHONE -->
              <div class="form-field" id="field-phone">
                <label for="phone" class="form-label">Phone Number</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  class="form-input"
                  placeholder="(555) 000-0000"
                  autocomplete="tel"
                  required
                />
                <span class="form-error" id="error-phone">Please enter a valid phone number.</span>
              </div>

              <button type="submit" class="btn btn--primary btn--full form-submit" id="submit-btn">
                <span id="btn-text">Show Me What My Business Is Losing</span>
                <span id="btn-loading" style="display:none;">
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none" class="spin" aria-hidden="true">
                    <circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="2" stroke-dasharray="25 15" opacity="0.8"/>
                  </svg>
                  Submitting...
                </span>
                <svg id="btn-arrow" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                  <path d="M3.75 9h10.5M9.75 4.5L14.25 9l-4.5 4.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>

              <p class="form-privacy">
                Your information is never sold or shared. Ever.
              </p>
              <p class="form-api-error" id="api-error" style="display:none;">Something went wrong. Please try again.</p>
            </form>
          </div>

          <!-- POST-SUBMISSION DISCLOSURE -->
          <div id="disclosure-view" style="display:none;" aria-live="polite">
            <div class="disclosure">
              <div class="disclosure__icon">
                <svg width="40" height="40" viewBox="0 0 40 40" fill="none" aria-hidden="true">
                  <circle cx="20" cy="20" r="20" fill="#171E62" opacity="0.1"/>
                  <path d="M12 20l6 6 10-12" stroke="#171E62" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <h3 class="disclosure__heading">One thing before you call.</h3>
              <p class="disclosure__body">
                You'll be speaking with <strong>Alex</strong>, our AI business analyst. Alex asks 8 focused questions about how your business runs, takes detailed notes, and hands everything directly to our team. We then build your personalized report within 24 hours.
              </p>
              <p class="disclosure__emphasis">
                No salesperson. No pitch. Just 12 minutes and you're done.
              </p>
              <p class="disclosure__cta-label">Ready? Call Alex now:</p>
              <a href="tel:+15406000080" class="disclosure__phone" id="alex-phone">
                (540) 600-0080
              </a>
              <p class="disclosure__hours">
                Available Mon–Fri 8am–8pm ET · Your report arrives within 24 hours of your call.
              </p>
            </div>
          </div>
        </div>

        <!-- IMAGE BELOW FORM -->
        <div class="form-image">
          <img
            src="/images/hero-jose.png"
            alt="Jose reviewing an AI & Automation Opportunity Report on his laptop"
            class="form-image__img"
            width="520"
            height="560"
            loading="lazy"
          />
        </div>

      </div>
    </section>

  </main>

  <!-- SLIM FOOTER -->
  <footer class="slim-footer">
    <div class="slim-footer__inner">
      <a href="/" class="slim-footer__logo" aria-label="ProActive Pixels home">
        <span class="logo-pro">Pro</span><span class="logo-active">Active</span><span class="logo-pixels">Pixels</span>
      </a>
      <p class="slim-footer__copy">&copy; {new Date().getFullYear()} ProActive Pixels LLC. All rights reserved.</p>
    </div>
  </footer>

</BaseLayout>

<style>
  /* ===================================
     HEADER
  =================================== */
  .site-header {
    padding: 18px 24px;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-header-border);
    position: sticky;
    top: 0;
    z-index: 100;
    transition: background-color 0.25s ease, border-color 0.25s ease;
  }
  .site-header__inner {
    max-width: var(--max-hero);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .site-logo {
    font-family: var(--font-body);
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1;
    user-select: none;
    text-decoration: none;
  }
  .logo-pro, .logo-pixels { color: var(--logo-main); transition: color 0.25s ease; }
  .logo-active { color: var(--logo-active); }

  .theme-toggle {
    display: flex;
    align-items: center;
    gap: 7px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px 8px;
    border-radius: var(--radius-pill);
    transition: opacity 0.2s ease;
  }
  .theme-toggle:hover { opacity: 0.85; }
  .toggle-icon--sun { color: #F0A020; transition: color 0.25s ease, opacity 0.25s ease; }
  .theme-toggle.is-dark .toggle-icon--sun { color: var(--color-muted); opacity: 0.5; }
  .toggle-icon--moon { color: var(--color-muted); opacity: 0.5; transition: color 0.25s ease, opacity 0.25s ease; }
  .theme-toggle.is-dark .toggle-icon--moon { color: var(--pp-sky); opacity: 1; }
  .toggle-track {
    display: inline-flex;
    align-items: center;
    width: 46px;
    height: 26px;
    border-radius: 999px;
    background: var(--pp-amber);
    padding: 3px;
    transition: background 0.25s ease;
  }
  .toggle-thumb {
    display: block;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: #171E62;
    transition: transform 0.25s ease, background 0.25s ease;
  }
  .theme-toggle.is-dark .toggle-thumb { transform: translateX(20px); background: #ffffff; }

  /* ===================================
     HERO
  =================================== */
  .hero {
    background-color: var(--color-bg);
    padding: 88px 24px 96px;
    text-align: center;
    overflow-x: hidden;
  }
  .hero__inner {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .hero__headline {
    font-family: var(--font-body);
    margin-bottom: 32px;
    letter-spacing: -0.02em;
  }
  @font-face {
    font-family: 'DSEG14Classic';
    src: url('https://cdn.jsdelivr.net/npm/dseg@0.46.0/fonts/DSEG14-Classic/DSEG14Classic-BoldItalic.woff2') format('woff2');
    font-weight: 700;
    font-style: italic;
    font-display: swap;
  }
  .hero__kicker {
    display: block;
    font-family: 'DSEG14Classic', 'DM Sans', sans-serif;
    font-style: italic;
    font-size: clamp(20px, 9vw, 80px);
    font-weight: 700;
    color: oklch(58% 0.22 145);
    text-shadow: 0 0 10px oklch(62% 0.24 145 / 0.3), 0 0 24px oklch(62% 0.24 145 / 0.12);
    line-height: 1.1;
    letter-spacing: 0;
    white-space: nowrap;
    margin: 0 0 28px -0.6em;
    padding: 0;
  }
  :global([data-theme="dark"]) .hero__kicker {
    color: oklch(70% 0.24 145);
    text-shadow: 0 0 12px oklch(70% 0.26 145 / 0.45), 0 0 30px oklch(70% 0.26 145 / 0.2);
  }
  .hero__tagline {
    display: block;
    font-size: clamp(20px, 2.8vw, 28px);
    font-weight: 400;
    color: var(--color-text-light);
    line-height: 1.45;
    max-width: 640px;
    margin: 0 auto;
    text-wrap: balance;
  }
  .hero__amount {
    color: var(--color-highlight);
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }
  .hero__subheadline {
    font-size: 18px;
    font-weight: 400;
    color: var(--color-body);
    line-height: 1.65;
    margin-bottom: 28px;
    max-width: 560px;
  }
  .hero__trust {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    margin-bottom: 40px;
    justify-content: center;
  }
  .hero__trust-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-muted);
  }
  .hero__trust-icon { color: oklch(58% 0.22 145); flex-shrink: 0; }
  :global([data-theme="dark"]) .hero__trust-icon { color: oklch(70% 0.24 145); }
  .hero__cta { font-size: 17px; min-width: 280px; }

  /* ===================================
     WHY FREE
  =================================== */
  .why-free {
    padding: 80px 24px;
    background: var(--color-bg-section);
  }
  .why-free__inner { max-width: 640px; margin: 0 auto; }
  .why-free__heading {
    font-family: var(--font-body);
    font-size: clamp(22px, 3vw, 28px);
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.01em;
    margin-bottom: 32px;
    text-wrap: balance;
  }
  .why-free__body {
    font-size: 17px;
    color: var(--color-body);
    line-height: 1.75;
    margin-bottom: 28px;
    text-wrap: pretty;
  }
  .why-free__roi {
    font-size: clamp(20px, 2.5vw, 24px);
    font-weight: 700;
    font-style: italic;
    color: var(--color-text);
    line-height: 1.55;
    margin-bottom: 36px;
    text-wrap: balance;
  }
  .why-free__closing {
    font-size: 16px;
    color: var(--color-muted);
    line-height: 1.75;
    text-wrap: pretty;
  }
  .why-free__anchor {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 20px 24px;
    margin-top: 40px;
  }
  .why-free__anchor-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 8px 0;
  }
  .why-free__anchor-row + .why-free__anchor-row { border-top: 1px solid var(--color-border); }
  .why-free__anchor-label { font-size: 14px; color: var(--color-muted); }
  .why-free__anchor-price {
    font-size: 15px;
    font-weight: 600;
    color: var(--color-body);
    text-decoration: line-through;
    opacity: 0.6;
    font-variant-numeric: tabular-nums;
  }
  .why-free__anchor-free {
    font-size: 15px;
    font-weight: 700;
    color: var(--pp-sky);
    font-variant-numeric: tabular-nums;
  }

  /* ===================================
     OBJECTIONS
  =================================== */
  .objections {
    padding: 80px 24px 100px;
    background: var(--color-bg);
  }
  .objections__inner { max-width: var(--max-content); margin: 0 auto; }
  .objections__heading {
    font-size: clamp(22px, 3vw, 28px);
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.01em;
    margin-bottom: 40px;
    text-wrap: balance;
  }
  .objection { padding-top: 40px; margin-bottom: 0; }
  .objection + .objection { border-top: 1px solid var(--color-border); }
  .objections__heading + .objection { padding-top: 0; }
  .objection:last-of-type { margin-bottom: 0; }
  .objection__quote {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: 10px;
    line-height: 1.5;
  }
  .objection__answer {
    font-size: 16px;
    color: var(--color-body);
    line-height: 1.75;
    text-wrap: pretty;
  }
  .objections__cta {
    margin-top: 60px;
    display: flex;
    justify-content: center;
  }

  /* ===================================
     FORM
  =================================== */
  .form-section {
    padding: 80px 24px;
    background: var(--color-bg-section);
  }
  .form-section__inner {
    max-width: var(--max-content);
    margin: 0 auto;
  }
  .form-card {
    background: var(--color-bg-card);
    border-radius: var(--radius-lg);
    padding: 48px 40px;
    box-shadow: var(--shadow-card);
  }
  .form-card__headline {
    font-family: var(--font-body);
    font-size: 26px;
    font-weight: 700;
    color: var(--color-text);
    text-align: center;
    margin-bottom: 8px;
    letter-spacing: -0.01em;
    text-wrap: balance;
  }
  .form-card__sub {
    font-size: 15px;
    color: var(--color-muted);
    text-align: center;
    margin-bottom: 32px;
  }
  .form-field { margin-bottom: 20px; }
  .form-label {
    display: block;
    font-size: 14px;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 8px;
    letter-spacing: 0.01em;
  }
  .form-input {
    width: 100%;
    padding: 14px 16px;
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--color-text);
    background: var(--color-input-bg);
    border: 1px solid var(--color-border-input);
    border-radius: var(--radius-sm);
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    appearance: none;
    -webkit-appearance: none;
  }
  .form-input:focus {
    border-color: var(--pp-sky);
    box-shadow: 0 0 0 3px rgba(64, 165, 221, 0.2);
  }
  .form-input.error {
    border-color: var(--color-error);
    box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.1);
  }
  .form-error {
    display: none;
    font-size: 13px;
    color: var(--color-error);
    margin-top: 6px;
  }
  .form-field.has-error .form-error { display: block; }
  .form-submit { margin-top: 10px; font-size: 16px; }
  .form-privacy {
    text-align: center;
    font-size: 12px;
    color: var(--color-muted);
    margin-top: 14px;
  }
  .form-api-error {
    text-align: center;
    font-size: 13px;
    color: var(--color-error);
    margin-top: 10px;
  }

  /* DISCLOSURE VIEW */
  .disclosure {
    text-align: center;
    animation: fadeUp 0.4s ease forwards;
  }
  .disclosure__icon { margin-bottom: 20px; display: flex; justify-content: center; }
  .disclosure__icon circle { fill: var(--pp-navy); }
  .disclosure__icon path { stroke: var(--pp-navy); }
  .disclosure__heading {
    font-family: var(--font-body);
    font-size: 24px;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 16px;
    letter-spacing: -0.01em;
    text-wrap: balance;
  }
  .disclosure__body {
