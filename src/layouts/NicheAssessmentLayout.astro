<script>
  const toggle = document.getElementById('theme-toggle') as HTMLButtonElement;

  function applyTheme(theme: 'light' | 'dark') {
    const isDark = theme === 'dark';
    if (isDark) {
      document.documentElement.setAttribute('data-theme', 'dark');
      toggle?.classList.add('is-dark');
      toggle?.setAttribute('aria-label', 'Switch to light mode');
    } else {
      document.documentElement.removeAttribute('data-theme');
      toggle?.classList.remove('is-dark');
      toggle?.setAttribute('aria-label', 'Switch to dark mode');
    }
    try { localStorage.setItem('pp-theme', theme); } catch (e) {}
  }

  if (document.documentElement.getAttribute('data-theme') === 'dark') {
    toggle?.classList.add('is-dark');
    toggle?.setAttribute('aria-label', 'Switch to light mode');
  }

  toggle?.addEventListener('click', () => {
    const isDark = toggle.classList.contains('is-dark');
    applyTheme(isDark ? 'light' : 'dark');
  });

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12 }
  );
  document.querySelectorAll('.fade-in').forEach((el) => { observer.observe(el); });
</script>

<script define:vars={{ nicheValue }}>
  const form = document.getElementById('leak-form');
  const formView = document.getElementById('form-view');
  const disclosureView = document.getElementById('disclosure-view');
  const submitBtn = document.getElementById('submit-btn');
  const btnText = document.getElementById('btn-text');
  const btnLoading = document.getElementById('btn-loading');
  const btnArrow = document.getElementById('btn-arrow');
  const apiError = document.getElementById('api-error');

  function validateField(id, errorId, validator) {
    const fieldWrapper = document.getElementById(id);
    const isValid = validator();
    if (!isValid) {
      fieldWrapper.classList.add('has-error');
      fieldWrapper.querySelector('.form-input')?.classList.add('error');
    } else {
      fieldWrapper.classList.remove('has-error');
      fieldWrapper.querySelector('.form-input')?.classList.remove('error');
    }
    return isValid;
  }

  function isValidPhone(phone) {
    return /^[\d\s\-\(\)\+]{7,15}$/.test(phone.trim());
  }

  function isValidEmail(email) {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.trim());
  }

  function resetButton() {
    btnText.style.display = '';
    btnArrow.style.display = '';
    btnLoading.style.display = 'none';
    submitBtn.disabled = false;
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const firstName = document.getElementById('first-name').value.trim();
    const email = document.getElementById('email').value.trim();
    const phone = document.getElementById('phone').value.trim();

    const nameValid = validateField('field-name', 'error-name', () => firstName.length > 0);
    const emailValid = validateField('field-email', 'error-email', () => isValidEmail(email));
    const phoneValid = validateField('field-phone', 'error-phone', () => isValidPhone(phone));

    if (!nameValid || !emailValid || !phoneValid) return;

    apiError.style.display = 'none';
    btnText.style.display = 'none';
    btnArrow.style.display = 'none';
    btnLoading.style.display = 'flex';
    submitBtn.disabled = true;

    try {
      const WEBHOOK_URL = 'https://proactivepixels-router.aqua-noriega.workers.dev/submit';

      const res = await fetch(WEBHOOK_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          first_name: firstName,
          niche: nicheValue,
          email: email,
          phone: phone,
        }),
      });

      if (!res.ok) {
        resetButton();
        apiError.style.display = 'block';
        return;
      }

      if (typeof window.gtag !== 'undefined') {
        window.gtag('event', 'form_submit', {
          event_category: 'Lead',
          event_label: nicheValue,
        });
      }
      if (typeof window.fbq !== 'undefined') {
        window.fbq('track', 'Lead', { business_type: nicheValue });
      }

      formView.style.display = 'none';
      disclosureView.style.display = 'block';
      disclosureView.scrollIntoView({ behavior: 'smooth', block: 'center' });

    } catch (err) {
      console.error('Form submission error:', err);
      resetButton();
      apiError.style.display = 'block';
      return;
    }
  });

  // Real-time validation on blur
  document.getElementById('first-name')?.addEventListener('blur', () => {
    const val = document.getElementById('first-name').value.trim();
    validateField('field-name', 'error-name', () => val.length > 0);
  });
  document.getElementById('email')?.addEventListener('blur', () => {
    const val = document.getElementById('email').value.trim();
    validateField('field-email', 'error-email', () => isValidEmail(val));
  });
  document.getElementById('phone')?.addEventListener('blur', () => {
    const val = document.getElementById('phone').value.trim();
    validateField('field-phone', 'error-phone', () => isValidPhone(val));
  });
</script>
