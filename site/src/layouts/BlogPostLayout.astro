---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import SiteFooter from '../components/SiteFooter.astro';

export interface Props {
  title: string;
  description: string;
  pubDate: string;
  readTime: string;
  category: string;
}

const { title, description, pubDate, readTime, category } = Astro.props;
---

<BaseLayout title={`${title} | ProActive Pixels`} description={description}>
  <Nav />

  <main class="blog-post-page">

    <div class="post-hero">
      <div class="container--narrow">
        <div class="post-meta">
          <a href="/blog" class="post-back">← All Articles</a>
          <span class="post-category">{category}</span>
        </div>
        <h1 class="post-title">{title}</h1>
        <p class="post-description">{description}</p>
        <div class="post-details">
          <time class="post-date">{pubDate}</time>
          <span class="post-divider">·</span>
          <span class="post-read-time">{readTime} read</span>
        </div>
      </div>
    </div>

    <article class="post-body container--narrow">
      <slot />
    </article>

    <div class="post-cta-strip">
      <div class="container--narrow">
        <div class="cta-strip-inner">
          <div class="cta-strip-text">
            <strong>Ready to fix your leaks?</strong> The audit is free, takes 5 minutes, and you'll have your Leak Report within 1 business day.
          </div>
          <a href="/assessment" class="btn btn--primary btn--sm">Get Your Free Leak Report →</a>
        </div>
      </div>
    </div>

  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .blog-post-page {
    background: var(--color-bg);
  }

  .post-hero {
    padding: 56px 0 48px;
    border-bottom: 1px solid var(--color-border);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
  }

  .post-back {
    font-size: 14px;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .post-back:hover {
    color: var(--pp-sky);
  }

  .post-category {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--pp-amber);
    background: rgba(245,166,35,0.12);
    padding: 3px 10px;
    border-radius: var(--radius-pill);
  }

  :global([data-theme="dark"]) .post-category {
    color: rgba(255, 255, 255, 0.9);
    background: rgba(255, 255, 255, 0.09);
  }

  .post-title {
    font-size: clamp(28px, 4.5vw, 44px);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.025em;
    color: var(--color-text);
    margin-bottom: 16px;
    text-wrap: balance;
  }

  .post-description {
    font-size: 18px;
    color: var(--color-body);
    line-height: 1.6;
    max-width: 60ch;
    text-wrap: pretty;
    margin-bottom: 20px;
  }

  .post-details {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: var(--color-muted);
  }

  .post-divider {
    opacity: 0.5;
  }

  /* Article body prose */
  .post-body {
    padding: 56px 24px 72px;
  }

  .post-body :global(h2) {
    font-size: 22px;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.02em;
    margin: 48px 0 16px;
    text-wrap: balance;
  }

  .post-body :global(h3) {
    font-size: 18px;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.01em;
    margin: 32px 0 12px;
  }

  .post-body :global(p) {
    font-size: 17px;
    line-height: 1.75;
    color: var(--color-body);
    margin-bottom: 20px;
    max-width: 65ch;
    text-wrap: pretty;
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    padding-left: 24px;
    margin-bottom: 20px;
  }

  .post-body :global(li) {
    font-size: 17px;
    line-height: 1.7;
    color: var(--color-body);
    margin-bottom: 8px;
  }

  .post-body :global(strong) {
    color: var(--color-text);
    font-weight: 600;
  }

  .post-body :global(blockquote) {
    margin: 32px 0;
    padding: 20px 24px;
    border-left: 3px solid var(--pp-sky);
    background: var(--color-bg-section);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }

  .post-body :global(blockquote p) {
    font-size: 18px;
    font-style: italic;
    color: var(--color-text);
    margin-bottom: 0;
  }

  .post-body :global(a) {
    color: var(--pp-sky);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post-body :global(a:hover) {
    color: var(--pp-ocean);
  }

  /* CTA strip */
  .post-cta-strip {
    background: var(--color-bg-section);
    border-top: 1px solid var(--color-border);
    padding: 28px 0;
  }

  .cta-strip-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }

  .cta-strip-text {
    font-size: 15px;
    color: var(--color-body);
    line-height: 1.5;
  }

  .cta-strip-text strong {
    color: var(--color-text);
  }
</style>
