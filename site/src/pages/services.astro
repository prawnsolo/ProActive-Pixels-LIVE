---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import SiteFooter from '../components/SiteFooter.astro';
---

<BaseLayout
  title="Services | ProActive Pixels — AI & Automation Implementation"
  description="We find the automation and AI gaps in your business, implement proven solutions, and maintain them long-term. No custom dev. No six-month timelines. Most clients live in 72 hours."
>
  <Nav currentPage="services" />

  <main>

    <!-- PAGE HERO -->
    <section class="page-hero">
      <div class="container">
        <div class="section-label fade-in">What We Do</div>
        <h1 class="page-headline fade-in fade-in-delay-1">
          Find the Leaks.<br>
          <span class="headline-accent">Fix Them Fast.</span><br>
          Keep Them Fixed.
        </h1>
        <p class="page-sub fade-in fade-in-delay-2">
          We don't sell software. We don't write code for months. We find exactly where
          your business is losing time and money to manual work, implement the right AI or
          automation tool, and make sure it keeps running.
        </p>
      </div>
    </section>

    <!-- PROCESS DEEP DIVE -->
    <section class="section-process">
      <div class="container">
        <div class="section-header fade-in">
          <div class="section-label">The Process</div>
          <h2 class="section-headline">Three Phases. No Surprises.</h2>
          <p class="section-sub">Every engagement follows the same repeatable process — because it works.</p>
        </div>

        <div class="phases">

          <!-- Phase 1 -->
          <div class="phase fade-in">
            <div class="phase-badge">Phase 1</div>
            <div class="phase-header">
              <span class="phase-icon">
                <svg width="32" height="32" viewBox="0 0 44 44" fill="none" aria-hidden="true">
                  <circle cx="19" cy="19" r="12" stroke="currentColor" stroke-width="2.5"/>
                  <path d="M28 28l8 8" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                  <path d="M14 18h10M14 23h6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
              </span>
              <h3 class="phase-title">Find — The Leak Report</h3>
            </div>
            <p class="phase-desc">
              We start with a free, no-pressure audit. You tell us about your business — how leads come in,
              how your team works, what a typical customer journey looks like from first contact to final invoice.
              We listen, map it out, and identify every place where time is wasted, revenue escapes, or a
              machine could replace a manual step.
            </p>
            <div class="phase-details">
              <div class="phase-detail-item">
                <span class="detail-label">What you get:</span>
                <span class="detail-val">A prioritized list of your top automation opportunities — ranked by ROI potential</span>
              </div>
              <div class="phase-detail-item">
                <span class="detail-label">Time to complete:</span>
                <span class="detail-val">1–2 business days after your intake call</span>
              </div>
              <div class="phase-detail-item">
                <span class="detail-label">Cost:</span>
                <span class="detail-val">Free</span>
              </div>
            </div>
          </div>

          <!-- Phase 2 -->
          <div class="phase fade-in">
            <div class="phase-badge">Phase 2</div>
            <div class="phase-header">
              <span class="phase-icon">
                <svg width="32" height="32" viewBox="0 0 44 44" fill="none" aria-hidden="true">
                  <circle cx="22" cy="22" r="18" stroke="currentColor" stroke-width="2.5"/>
                  <path d="M25 11L17 24h8L19 37" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <h3 class="phase-title">Implement — Live in 72 Hours</h3>
            </div>
            <p class="phase-desc">
              Once we align on the highest-priority fix, we get to work. We don't build from scratch —
              we configure and connect battle-tested AI platforms and automation tools that are already
              proven in production. We handle the setup, the testing, and the go-live. Your job is to
              review and approve. Most solutions are running within 72 hours.
            </p>
            <div class="phase-details">
              <div class="phase-detail-item">
                <span class="detail-label">What you get:</span>
                <span class="detail-val">A live, tested solution integrated with your existing systems</span>
              </div>
              <div class="phase-detail-item">
                <span class="detail-label">Typical timeline:</span>
                <span class="detail-val">48–72 hours from kickoff to live</span>
              </div>
              <div class="phase-detail-item">
                <span class="detail-label">You need:</span>
                <span class="detail-val">Access to your existing tools and an hour to review before launch</span>
              </div>
            </div>
          </div>

          <!-- Phase 3 -->
          <div class="phase fade-in">
            <div class="phase-badge">Phase 3</div>
            <div class="phase-header">
              <span class="phase-icon">
                <svg width="32" height="32" viewBox="0 0 44 44" fill="none" aria-hidden="true">
                  <path d="M22 4L8 10v12c0 9.5 6.2 16.5 14 18.5C29.8 38.5 36 31.5 36 22V10L22 4z" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round"/>
                  <path d="M15 22l5 5 9-9" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <h3 class="phase-title">Maintain — Your AI Partner, Long-Term</h3>
            </div>
            <p class="phase-desc">
              AI tools don't maintain themselves. Integrations break when platforms update. Prompts drift
              over time. A solution that worked perfectly in month one can quietly degrade by month three
              if nobody's watching. We watch. We alert you before issues become problems, and we continuously
              tune your solutions as your business evolves.
            </p>
            <div class="phase-details">
              <div class="phase-detail-item">
                <span class="detail-label">What's included:</span>
                <span class="detail-val">Monthly monitoring, proactive fixes, and performance reporting</span>
              </div>
              <div class="phase-detail-item">
                <span class="detail-label">Also included:</span>
                <span class="detail-val">Ongoing improvements and new automation discovery as your business grows</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- WHAT WE IMPLEMENT -->
    <section class="section-solutions">
      <div class="container">
        <div class="section-header fade-in" style="text-align:center; max-width:600px; margin:0 auto 56px;">
          <div class="section-label">Solutions We Implement</div>
          <h2 class="section-headline">The Tools Are Proven.<br>The Setup Is Custom.</h2>
          <p class="section-sub" style="margin:0 auto;">
            We don't reinvent the wheel. We configure the best available AI and automation tools
            precisely for your business, workflow, and customer base.
          </p>
        </div>

        <div class="solutions-list">
          <div class="solution-item fade-in">
            <div class="solution-num">01</div>
            <div class="solution-body">
              <h3 class="solution-title">Voice AI Receptionist</h3>
              <span class="solution-tag">Most Popular First Solution</span>
              <p class="solution-desc">Never miss a call again. Our AI receptionist answers every call, qualifies leads with your questions, books appointments to your calendar, and sends follow-up texts around the clock.</p>
            </div>
          </div>

          <div class="solution-item fade-in">
            <div class="solution-num">02</div>
            <div class="solution-body">
              <h3 class="solution-title">Lead Follow-Up Automation</h3>
              <p class="solution-desc">Most businesses give up after 1–2 follow-up attempts. The data says it takes 5–8. We automate your entire follow-up sequence (SMS, email, voicemail drops) so no lead goes cold.</p>
            </div>
          </div>

          <div class="solution-item fade-in">
            <div class="solution-num">03</div>
            <div class="solution-body">
              <h3 class="solution-title">Intake & Onboarding Automation</h3>
              <p class="solution-desc">Replace manual intake forms, back-and-forth emails, and data entry with automated onboarding flows. Clients fill out one form; everything else happens automatically.</p>
            </div>
          </div>

          <div class="solution-item fade-in">
            <div class="solution-num">04</div>
            <div class="solution-body">
              <h3 class="solution-title">Scheduling & Reminder Systems</h3>
              <p class="solution-desc">Automated appointment booking, reminders, and no-show follow-ups. We reduce your cancellation rate and fill the gaps on your calendar automatically.</p>
            </div>
          </div>

          <div class="solution-item fade-in">
            <div class="solution-num">05</div>
            <div class="solution-body">
              <h3 class="solution-title">Review & Reputation Automation</h3>
              <p class="solution-desc">Automatically request reviews from happy customers at the right moment, route unhappy customers to internal feedback, and monitor your reputation across platforms.</p>
            </div>
          </div>

          <div class="solution-item fade-in">
            <div class="solution-num">06</div>
            <div class="solution-body">
              <h3 class="solution-title">CRM & Data Workflows</h3>
              <p class="solution-desc">Eliminate manual data entry. We connect your tools (lead forms, CRM, accounting software) so data flows automatically and your team focuses on revenue.</p>
            </div>
          </div>
        </div>

        <div class="solutions-note fade-in">
          <p>Don't see your specific need? <a href="/assessment">Tell us what you're dealing with →</a> We audit first, then recommend the right solution.</p>
        </div>
      </div>
    </section>

    <!-- ENGAGEMENT MODEL -->
    <section class="section-engagement">
      <div class="container">
        <div class="engagement-inner fade-in">
          <div class="section-label">How We Engage</div>
          <h2 class="section-headline">Simple Pricing. No Surprises.</h2>
          <p class="section-sub">
            We work on a monthly retainer — one flat fee covers implementation, maintenance, monitoring,
            and ongoing improvements. The audit is always free.
          </p>

          <div class="engagement-tiers">
            <div class="tier-card">
              <div class="tier-label">Starter</div>
              <div class="tier-headline">One Solution, Fully Managed</div>
              <p class="tier-desc">
                Perfect for businesses ready to fix their #1 leak. We implement one automation or AI
                solution and maintain it long-term.
              </p>
              <ul class="tier-includes">
                <li>✓ Free Leak Report audit</li>
                <li>✓ One solution implemented</li>
                <li>✓ Ongoing monitoring & maintenance</li>
                <li>✓ Monthly performance report</li>
              </ul>
              <a href="/assessment" class="btn btn--primary">Get Free Audit →</a>
            </div>

            <div class="tier-card tier-card--featured">
              <div class="tier-chip">Most Popular</div>
              <div class="tier-label">Growth</div>
              <div class="tier-headline">Full Automation Stack</div>
              <p class="tier-desc">
                For businesses ready to systematically plug every leak. We identify and implement
                your entire automation roadmap, starting with highest ROI.
              </p>
              <ul class="tier-includes">
                <li>✓ Everything in Starter</li>
                <li>✓ Multiple solutions in priority order</li>
                <li>✓ Continuous discovery of new opportunities</li>
                <li>✓ Priority support & faster turnarounds</li>
              </ul>
              <a href="/assessment" class="btn btn--primary">Get Free Audit →</a>
            </div>
          </div>

          <p class="pricing-note">Exact pricing depends on your solutions and stack. We share exact numbers after the audit — no surprises.</p>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section-faq">
      <div class="container">
        <div class="section-header fade-in" style="max-width:600px;">
          <div class="section-label">Questions</div>
          <h2 class="section-headline">The Ones We Hear Most</h2>
        </div>

        <div class="faq-list">
          <div class="faq-item fade-in">
            <h3 class="faq-q">Do I need to know anything about AI or automation?</h3>
            <p class="faq-a">Not at all. You tell us about your business. We handle everything technical — setup, configuration, testing, training. You just review and approve before we go live.</p>
          </div>

          <div class="faq-item fade-in">
            <h3 class="faq-q">Will this replace my team?</h3>
            <p class="faq-a">No — and that's not the goal. Automation handles the repetitive, low-value tasks (answering the same questions, moving data between systems, sending follow-up #4). Your team focuses on the work that actually requires a human. Most clients find their team is happier and more productive after implementation.</p>
          </div>

          <div class="faq-item fade-in">
            <h3 class="faq-q">How quickly can I see results?</h3>
            <p class="faq-a">Most solutions are live within 72 hours. Results depend on the solution — a Voice AI receptionist captures value the same day it's live. A lead nurture sequence shows ROI over the first 30 days as leads move through it.</p>
          </div>

          <div class="faq-item fade-in">
            <h3 class="faq-q">What if it breaks or doesn't work right?</h3>
            <p class="faq-a">That's exactly why we maintain. Our monthly retainer includes proactive monitoring. We catch most issues before they affect your business, and if something goes wrong, fixing it is our problem — not yours.</p>
          </div>

          <div class="faq-item fade-in">
            <h3 class="faq-q">Do you build custom software?</h3>
            <p class="faq-a">Rarely. 95% of what businesses need already exists as proven, production-ready AI and automation tools. Custom software takes months and costs $30–50K. Configuring the right tool takes 72 hours and costs a fraction of that. We choose the right tool for the job — not the one that sounds most impressive.</p>
          </div>

          <div class="faq-item fade-in">
            <h3 class="faq-q">What kinds of businesses do you work with?</h3>
            <p class="faq-a">Primarily local service businesses — HVAC, roofing, plumbing, med spas, dental practices, law firms, real estate teams, and similar. If you have a phone, customers, and manual processes, we can almost certainly find significant automation opportunities.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section-cta">
      <div class="container">
        <div class="cta-inner fade-in">
          <div class="section-label">Start Here</div>
          <h2 class="cta-headline">Get Your Free Leak Report</h2>
          <p class="cta-sub">
            Takes 5 minutes. We'll identify your top 3–5 automation opportunities — and exactly how
            much time or revenue each one is costing you — at no charge and no commitment.
          </p>
          <a href="/assessment" class="btn btn--white btn--lg">Start the Free Audit →</a>
          <p class="cta-fine">We respond within 1 business day.</p>
        </div>
      </div>
    </section>

  </main>

  <SiteFooter />
</BaseLayout>

<style>
  /* PAGE HERO */
  .page-hero {
    padding: 80px 0 72px;
    background: var(--color-bg);
  }

  .page-headline {
    font-size: clamp(36px, 5.5vw, 58px);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin-bottom: 24px;
    text-wrap: balance;
  }

  .headline-accent {
    color: var(--pp-amber);
  }

  .page-sub {
    font-size: 18px;
    color: var(--color-body);
    line-height: 1.65;
    max-width: 580px;
  }

  /* PROCESS */
  .section-process {
    padding: 96px 0;
    background: var(--color-bg-section);
  }

  .section-header {
    margin-bottom: 56px;
  }

  .phases {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .phase {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 40px 40px 36px;
    box-shadow: var(--shadow-card);
    position: relative;
  }

  .phase-badge {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--pp-navy);
    background: rgba(245,166,35,0.18);
    padding: 4px 10px;
    border-radius: var(--radius-pill);
    display: inline-block;
    margin-bottom: 16px;
  }

  .phase-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 16px;
  }

  .phase-icon {
    color: var(--pp-sky);
    line-height: 0;
    flex-shrink: 0;
  }

  .phase-title {
    font-size: 22px;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.02em;
  }

  .phase-desc {
    font-size: 16px;
    color: var(--color-body);
    line-height: 1.7;
    max-width: 720px;
    margin-bottom: 28px;
  }

  .phase-details {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-top: 20px;
    border-top: 1px solid var(--color-border);
  }

  .phase-detail-item {
    display: flex;
    gap: 12px;
    font-size: 14px;
  }

  .detail-label {
    font-weight: 600;
    color: var(--color-text);
    min-width: 140px;
    flex-shrink: 0;
  }

  .detail-val {
    color: var(--color-body);
  }

  /* SOLUTIONS */
  .section-solutions {
    padding: 96px 0;
    background: var(--color-bg);
  }

  .solutions-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    margin-bottom: 40px;
  }

  .solution-item {
    display: flex;
    gap: 20px;
    align-items: flex-start;
    padding: 28px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .solution-item:nth-child(odd) {
    padding-right: 40px;
    border-right: 1px solid var(--color-border);
  }

  .solution-item:nth-child(even) {
    padding-left: 40px;
  }

  .solution-item:nth-last-child(-n+2) {
    border-bottom: none;
  }

  .solution-num {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--pp-amber);
    flex-shrink: 0;
    padding-top: 3px;
    font-variant-numeric: tabular-nums;
  }

  .solution-body {
    flex: 1;
  }

  .solution-title {
    font-size: 17px;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.01em;
    margin-bottom: 6px;
  }

  .solution-desc {
    font-size: 14px;
    color: var(--color-body);
    line-height: 1.65;
    text-wrap: pretty;
  }

  .solution-tag {
    display: inline-block;
    margin-bottom: 8px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--pp-navy);
    background: rgba(245,166,35,0.18);
    padding: 3px 8px;
    border-radius: var(--radius-pill);
  }

  .solutions-note {
    text-align: center;
    font-size: 15px;
    color: var(--color-muted);
    padding: 20px;
    background: var(--color-bg-section);
    border-radius: var(--radius-md);
  }

  .solutions-note a {
    color: var(--pp-sky);
    font-weight: 500;
    text-decoration: none;
  }

  .solutions-note a:hover {
    text-decoration: underline;
  }

  /* ENGAGEMENT */
  .section-engagement {
    padding: 96px 0;
    background: var(--color-bg-section);
  }

  .engagement-inner {
    max-width: 880px;
    margin: 0 auto;
  }

  .engagement-tiers {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    margin: 48px 0 24px;
  }

  .tier-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 36px 32px;
    box-shadow: var(--shadow-card);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .tier-card--featured {
    border-color: var(--pp-amber);
    box-shadow: 0 0 0 2px rgba(245,166,35,0.25), var(--shadow-card);
  }

  .tier-chip {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--pp-amber);
    color: var(--pp-navy);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 4px 14px;
    border-radius: var(--radius-pill);
    white-space: nowrap;
  }

  .tier-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--pp-amber);
    margin-bottom: 8px;
  }

  .tier-headline {
    font-size: 20px;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.02em;
    margin-bottom: 12px;
  }

  .tier-desc {
    font-size: 14px;
    color: var(--color-body);
    line-height: 1.65;
    margin-bottom: 20px;
  }

  .tier-includes {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 28px;
    flex: 1;
  }

  .tier-includes li {
    font-size: 14px;
    color: var(--color-body);
  }

  .pricing-note {
    text-align: center;
    font-size: 14px;
    color: var(--color-muted);
  }

  /* FAQ */
  .section-faq {
    padding: 80px 0 96px;
    background: var(--color-bg);
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    max-width: 720px;
  }

  .faq-item {
    padding: 28px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .faq-item:first-of-type {
    border-top: 1px solid var(--color-border);
  }

  .faq-q {
    font-size: 17px;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: -0.01em;
    margin-bottom: 10px;
  }

  .faq-a {
    font-size: 15px;
    color: var(--color-body);
    line-height: 1.7;
  }

  /* CTA */
  .section-cta {
    padding: 96px 0;
    background: var(--pp-navy);
  }

  [data-theme="dark"] .section-cta {
    background: var(--color-bg-dark);
  }

  .section-cta .section-label {
    color: rgba(255, 255, 255, 0.85);
  }

  .cta-inner {
    text-align: center;
    max-width: 620px;
    margin: 0 auto;
  }

  .cta-headline {
    font-size: clamp(30px, 4.5vw, 48px);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: #ffffff;
    margin-bottom: 20px;
  }

  .cta-sub {
    font-size: 17px;
    color: rgba(255,255,255,0.88);
    line-height: 1.65;
    margin-bottom: 36px;
  }

  .cta-fine {
    margin-top: 16px;
    font-size: 13px;
    color: rgba(255,255,255,0.75);
  }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .engagement-tiers {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .solutions-list {
      grid-template-columns: 1fr;
    }
    .solution-item:nth-child(odd) {
      padding-right: 0;
      border-right: none;
    }
    .solution-item:nth-child(even) {
      padding-left: 0;
    }
    .solution-item:nth-last-child(-n+2) {
      border-bottom: 1px solid var(--color-border);
    }
    .solution-item:last-child {
      border-bottom: none;
    }
    .phase {
      padding: 28px 24px;
    }
    .phase-details {
      flex-direction: column;
    }
    .detail-label {
      min-width: unset;
    }
  }
</style>
